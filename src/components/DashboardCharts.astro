---
interface Props {
  data: number[];
  labels: string[];
  height?: number;
  color?: string;
}

const { data, labels, height = 120, color = "#C9A24D" } = Astro.props;

const max = Math.max(...data, 1);
const bars = data.map((v, i) => ({
  value: v,
  label: labels[i],
  height: (v / max) * 100,
}));
---

<div class="chart-container" style={`--chart-height: ${height}px; --chart-color: ${color};`}>
  <div class="bars-area">
    {bars.map((bar) => (
      <div class="bar-wrapper">
        <div class="bar-tooltip">{bar.value}</div>
        <div class="bar" style={`height: ${bar.height}%`}></div>
        <span class="bar-label">{bar.label}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .chart-container {
    width: 100%;
    height: var(--chart-height);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: 2rem;
  }

  .bars-area {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 100%;
    gap: 8px;
  }

  .bar-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
    position: relative;
    group: hover;
  }

  .bar {
    width: 100%;
    background-color: var(--chart-color);
    border-radius: 4px 4px 0 0;
    opacity: 0.6;
    transition: all 0.3s ease;
    min-height: 2px;
  }

  .bar-wrapper:hover .bar {
    opacity: 1;
    filter: brightness(1.2);
    box-shadow: 0 0 15px var(--chart-color);
  }

  .bar-label {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 8px;
    white-space: nowrap;
    opacity: 0.8;
  }

  .bar-tooltip {
    position: absolute;
    top: -25px;
    background: var(--primary);
    color: black;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .bar-wrapper:hover .bar-tooltip {
    opacity: 1;
  }
</style>
