---
interface Appointment {
  id: string;
  data_hora: string;
  cliente: { nome: string };
  tatuador: { nome: string };
  status: 'Pendente' | 'Confirmado' | 'Cancelado' | 'Falta';
  agendamento_referencias?: { storage_path: string }[];
}

interface Props {
  appointments: Appointment[];
}

const { appointments } = Astro.props;

// Ordenação inicial (SSR)
const sortedAppointments = [...appointments].sort((a, b) => 
  new Date(a.data_hora).getTime() - new Date(b.data_hora).getTime()
);

const statusMap = {
  Pendente: { label: 'Pendente', class: 'status-pending' },
  Confirmado: { label: 'Confirmado', class: 'status-confirmed' },
  Cancelado: { label: 'Cancelado', class: 'status-cancelled' },
  Falta: { label: 'Falta', class: 'status-missed' },
};
---

<div class="premium-appointment-container">
  {(!sortedAppointments || sortedAppointments.length === 0) ? (
    <div class="empty-state-card">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="empty-icon"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
      <p>Nenhum agendamento para hoje.</p>
    </div>
  ) : (
    <div class="appointment-table">
      <!-- Cabeçalho (Opcional, mas ajuda no Grid) -->
      <div class="table-header-row">
        <span>Horário</span>
        <span>Cliente</span>
        <span>Tatuador</span>
        <span class="text-right">Status</span>
      </div>

      <div class="appointment-rows">
        {sortedAppointments.map((app) => {
          const time = new Date(app.data_hora).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
          const statusInfo = statusMap[app.status] || { label: app.status, class: '' };
          
          return (
            <div class="appointment-grid-item" data-id={app.id}>
              <div class="col-time">
                <span class="time-main">{time}</span>
              </div>
              <div class="col-client">
                <span class="client-name-bold">{app.cliente.nome}</span>
              </div>
              <div class="col-artist">
                <span class="artist-name-muted">{app.tatuador.nome}</span>
              </div>
              <div class="col-status">
                 <span class={`status-pill ${statusInfo.class}`}>
                  {statusInfo.label}
                 </span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <div id="lightbox">
    <button class="lightbox-close">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <img id="lightbox-img" src="" alt="Referência Ampliada" />
  </div>
</div>

<style>
  .premium-appointment-container {
    width: 100%;
  }

  .empty-state-card {
    padding: 4rem;
    text-align: center;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.02);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    border: 1px dashed rgba(255, 255, 255, 0.1);
  }

  .empty-icon {
    opacity: 0.3;
  }

  .appointment-table {
    display: flex;
    flex-direction: column;
  }

  .table-header-row {
    display: grid;
    grid-template-columns: 100px 1.5fr 1fr 120px;
    padding: 0 1.5rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .appointment-grid-item {
    display: grid;
    grid-template-columns: 100px 1.5fr 1fr 120px;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }

  .appointment-grid-item:last-child {
    border-bottom: none;
  }

  .appointment-grid-item:hover {
    background: rgba(255, 255, 255, 0.03);
    transform: translateX(8px);
  }

  .time-main {
    font-family: var(--font-text);
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--primary);
  }

  .client-name-bold {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text);
  }

  .artist-name-muted {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .col-status {
    display: flex;
    justify-content: flex-end;
  }

  .status-pill {
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    min-width: 100px;
    text-align: center;
    border: 1px solid transparent;
  }

  .text-right { text-align: right; }

  /* Status Styles using Global Variables */
  .status-confirmed {
    background: rgba(39, 174, 96, 0.1);
    color: var(--status-confirmed);
    border-color: rgba(39, 174, 96, 0.2);
  }

  .status-pending {
    background: rgba(201, 162, 77, 0.1);
    color: var(--status-pending);
    border-color: rgba(201, 162, 77, 0.2);
  }

  .status-cancelled {
    background: rgba(192, 57, 43, 0.1);
    color: var(--status-cancelled);
    border-color: rgba(192, 57, 43, 0.2);
  }

  .status-missed {
    background: rgba(109, 40, 217, 0.1);
    color: var(--status-missed);
    border-color: rgba(109, 40, 217, 0.2);
  }

  /* Lightbox Styles */
  #lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
    z-index: 2000;
    display: none !important;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  #lightbox.active {
    display: flex !important;
  }

  #lightbox img {
    max-width: 90%;
    max-height: 90%;
    border-radius: 12px;
    box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 0.5rem;
  }

  @media (max-width: 768px) {
    .table-header-row {
      display: none;
    }
    .appointment-grid-item {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      padding: 1.5rem;
    }
    .col-status {
      grid-column: span 2;
      justify-content: flex-start;
      margin-top: 0.5rem;
    }
  }
</style>
