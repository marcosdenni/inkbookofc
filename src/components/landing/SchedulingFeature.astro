---
---
<section class="sched">
  <div class="container">

    <!-- Topo: Copy centralizado -->
    <div class="sched__head reveal">
      <p class="sched__eyebrow">Agenda & Automação</p>
      <h2 class="sched__h2">
        Sua agenda organizada.<br/>
        <span class="gold-text">Seu WhatsApp no piloto automático.</span>
      </h2>
      <p class="sched__sub">
        Do agendamento à confirmação — tudo acontece sozinho. O InkBook envia lembretes, confirma horários e permite que o cliente cancele instantaneamente se necessário.
      </p>
    </div>

    <!-- Features row -->
    <div class="sched__features reveal delay-100" data-stagger>
      <div class="sched__feat">
        <span class="sched__feat-icon sched__feat-icon--gold">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </span>
        <div>
          <strong><span class="gold-text">Lembretes</span> automáticos</strong>
          <p>Seu cliente recebe uma mensagem profissional no <span class="gold-text">WhatsApp</span> horas antes da sessão, sem você digitar nada.</p>
        </div>
      </div>
      <div class="sched__feat">
        <span class="sched__feat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
        </span>
        <div>
          <strong>Confirmação com 1 resposta</strong>
          <p>O cliente responde "1" no WhatsApp e o horário é confirmado instantaneamente na agenda.</p>
        </div>
      </div>
      <div class="sched__feat">
        <span class="sched__feat-icon sched__feat-icon--red">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m14 14-4 4"/><path d="m10 14 4 4"/></svg>
        </span>
        <div>
          <strong>Cancelamento Inteligente</strong>
          <p>Se o cliente responder "2" no WhatsApp, a sessão é cancelada e o horário liberado na hora.</p>
        </div>
      </div>
      <div class="sched__feat">
        <span class="sched__feat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </span>
        <div>
          <strong>Agenda em tempo real</strong>
          <p>Cada confirmação ou cancelamento aparece instantaneamente no seu painel.</p>
        </div>
      </div>
    </div>

    <!-- Imagem full-width abaixo -->
    <div class="sched__visual reveal delay-200">
      <div class="sched__frame">
        <div class="sched__screen-bar">
          <span class="sbar-d red"></span>
          <span class="sbar-d yellow"></span>
          <span class="sbar-d green"></span>
          <span class="sbar-url">inkbook.app/agenda</span>
        </div>
        <img
          src="/imagens/Captura de Tela (854).png"
          alt="Agenda semanal InkBook com agendamentos confirmados"
          class="sched__img"
          loading="lazy"
        />
      </div>
    </div>

    <div class="sched__footer-cta reveal">
      <a href="/login" class="sched__cta">
        Ver como funciona
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  :global(.sched .container) {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 4rem;
  }
  @media (max-width: 1024px) {
    :global(.sched .container) { padding: 0 2.5rem; }
  }
  @media (max-width: 768px) {
    :global(.sched .container) { padding: 0 1.5rem; }
  }

  .sched {
    background: #060606;
    padding: 10rem 0;
    border-top: 1px solid rgba(255,255,255,0.03);
  }
  @media (max-width: 768px) {
    .sched { padding: 6rem 0; }
  }

  /* Head */
  .sched__head {
    text-align: center;
    max-width: 860px;
    margin: 0 auto 5rem;
  }
  .sched__eyebrow {
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    color: #C9A24D; margin-bottom: 1.5rem;
  }
  .sched__h2 {
    font-family: var(--font-title);
    font-size: clamp(3rem, 5vw, 5.5rem);
    line-height: 0.95; color: #fff; margin-bottom: 1.5rem;
  }
  .sched__sub {
    font-size: 1.15rem; line-height: 1.7;
    color: rgba(255,255,255,0.4);
    max-width: 640px;
    margin: 0 auto;
  }

  /* Features horizontal row */
  .sched__features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
  @media (max-width: 992px) {
    .sched__features { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  }
  @media (max-width: 600px) {
    .sched__features { grid-template-columns: 1fr; gap: 1rem; }
  }

  .sched__feat {
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    transition: border-color 0.25s, background 0.25s;
  }
  .sched__feat:hover {
    background: #111;
    border-color: rgba(201,162,77,0.15);
  }
  .sched__feat-icon {
    width: 40px; height: 40px; flex-shrink: 0;
    border-radius: 10px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.4);
  }
  .sched__feat-icon--gold {
    background: rgba(201,162,77,0.08);
    border-color: rgba(201,162,77,0.2);
    color: #C9A24D;
  }
  .sched__feat-icon--red {
    background: rgba(192,57,43,0.08);
    border-color: rgba(192,57,43,0.2);
    color: #e74c3c;
  }
  .sched__feat div strong {
    display: block; font-size: 0.92rem;
    font-weight: 700; color: #fff; margin-bottom: 0.4rem;
  }
  .sched__feat div p {
    font-size: 0.84rem; color: rgba(255,255,255,0.35); line-height: 1.55;
  }

  /* Screenshot full-width */
  .sched__visual {
    position: relative;
    margin-bottom: 3.5rem;
  }
  .sched__frame {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
    box-shadow: 0 40px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.03);
    background: #111;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .sched__frame:hover {
    transform: perspective(1200px) translateY(-10px) scale(1.01);
    border-color: rgba(201,162,77,0.4);
    box-shadow: 0 60px 100px rgba(0,0,0,0.8), 0 0 40px rgba(201,162,77,0.1);
  }
  .sched__screen-bar {
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .sbar-d { width: 10px; height: 10px; border-radius: 50%; }
  .sbar-d.red { background: #FF5F56; }
  .sbar-d.yellow { background: #FFBD2E; }
  .sbar-d.green { background: #27C93F; }
  .sbar-url {
    flex: 1; text-align: center;
    font-family: monospace; font-size: 0.72rem;
    color: rgba(255,255,255,0.2);
  }
  .sched__img { display: block; width: 100%; height: auto; max-height: 520px; object-fit: cover; object-position: top; }

  /* Floating cards */
  .sched__float {
    position: absolute;
    background: rgba(10,10,10,0.95);
    backdrop-filter: blur(20px);
    border-radius: 14px;
    padding: 0.9rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    box-shadow: 0 16px 40px rgba(0,0,0,0.6);
    min-width: 220px;
    z-index: 10;
  }
  .sched__float--tl {
    top: 1.5rem; left: 1.5rem;
    border: 1px solid rgba(201,162,77,0.2);
    animation: floatA 4s ease-in-out infinite alternate;
  }
  .sched__float--br {
    bottom: 1.5rem; right: 1.5rem;
    border: 1px solid rgba(39,174,96,0.2);
    animation: floatB 4.5s ease-in-out infinite alternate;
  }
  @keyframes floatA {
    from { transform: translateY(0); }
    to   { transform: translateY(-8px); }
  }
  @keyframes floatB {
    from { transform: translateY(-5px); }
    to   { transform: translateY(5px); }
  }
  @media (max-width: 600px) {
    .sched__float { display: none; }
  }

  .sched__float-icon { font-size: 1.2rem; flex-shrink: 0; }
  .sched__float-title { font-size: 0.88rem; font-weight: 700; color: #fff; }
  .sched__float-sub { font-size: 0.76rem; color: rgba(255,255,255,0.35); margin-top: 2px; }
  .sched__float-badge {
    margin-left: auto; width: 24px; height: 24px;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
  }
  .sched__float-badge.ok {
    background: rgba(39,174,96,0.15);
    border: 1px solid rgba(39,174,96,0.3);
    color: #27AE60;
  }

  /* Footer CTA */
  .sched__footer-cta {
    display: flex;
    justify-content: center;
  }
  .sched__cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: #C9A24D; font-weight: 700; font-size: 1.05rem;
    text-decoration: none;
    border-bottom: 1px solid rgba(201,162,77,0.3);
    padding-bottom: 4px;
    transition: all 0.2s;
  }
  .sched__cta:hover {
    color: #E8CC7A;
    border-color: rgba(232,204,122,0.5);
    gap: 0.9rem;
  }
</style>
