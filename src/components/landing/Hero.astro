---
---
<section class="section hero-section reveal">
    <div class="container hero-container">
        <div class="hero-content">
            <h1 class="heading-massive">
                Transforme seu estúdio em uma <span class="gold-gradient-text">máquina de agendamentos.</span>
            </h1>
            <p class="text-body-large hero-subtitle">
                A gestão completa que entende a arte da tatuagem. Automatize seu WhatsApp, receba depósitos caução e organize sua agenda em um só lugar.
            </p>
            <div class="hero-actions">
                <a href="/cadastro" class="btn-large btn-primary">Começar agora</a>
                <a href="/login" class="btn-large btn-outline">Entrar</a>
            </div>
        </div>

        <div class="hero-visual reveal delay-200">
            <div class="mockup-container glass-card">
                <!-- Mockup de UI interna simulado em HTML/CSS para performance e estética -->
                <div class="mockup-header">
                    <div class="window-controls">
                        <span class="dot red"></span>
                        <span class="dot yellow"></span>
                        <span class="dot green"></span>
                    </div>
                    <div class="ds-text">inkbook.app/dashboard</div>
                </div>
                <div class="mockup-body">
                    <div class="sidebar">
                        <div class="skeleton-line title"></div>
                        <div class="skeleton-line"></div>
                        <div class="skeleton-line"></div>
                        <div class="skeleton-line"></div>
                        <div class="skeleton-line"></div>
                    </div>
                    <div class="main-content">
                        <div class="top-cards">
                            <div class="mockup-card">
                                <span class="card-title">Agendamentos hoje</span>
                                <span class="card-value">4 Sessões</span>
                            </div>
                            <div class="mockup-card">
                                <span class="card-title">Depósitos Confirmados</span>
                                <span class="card-value text-success">R$ 1.250,00</span>
                            </div>
                        </div>
                        <div class="agenda-view">
                            <div class="agenda-item">
                                <div class="time">14:00</div>
                                <div class="details">
                                    <span class="client">João Silva - Realismo</span>
                                    <span class="status status-confirmed">Confirmado via Pix</span>
                                </div>
                            </div>
                            <div class="agenda-item">
                                <div class="time">16:30</div>
                                <div class="details">
                                    <span class="client">Ana Costa - Old School</span>
                                    <span class="status status-pending">Aguardando Caução</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Decoração Brilho Atrás -->
            <div class="glow-effect"></div>
        </div>
    </div>
</section>

<style>
    .hero-section {
        padding-top: 180px;
        padding-bottom: 100px;
        position: relative;
        overflow: hidden;
    }

    .hero-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    @media (max-width: 992px) {
        .hero-container {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 3rem;
        }
    }

    .hero-subtitle {
        margin-bottom: 3rem;
    }

    @media (max-width: 992px) {
        .hero-subtitle {
            margin: 0 auto 3rem auto;
        }
        .hero-actions {
            justify-content: center;
        }
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-large {
        padding: 1.1rem 2.5rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-primary {
        background: var(--text);
        color: var(--background);
        border: 2px solid var(--text);
    }
    .btn-primary:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 30px rgba(255,255,255, 0.15);
        background: var(--primary);
        color: #000;
        border-color: var(--primary);
    }

    .btn-outline {
        background: transparent;
        color: var(--text);
        border: 2px solid rgba(255, 255, 255, 0.2);
    }
    .btn-outline:hover {
        border-color: var(--text);
        background: rgba(255,255,255,0.05);
    }

    /* MOCKUP UI */
    .hero-visual {
        position: relative;
        perspective: 1200px;
    }

    .mockup-container {
        position: relative;
        z-index: 2;
        padding: 0;
        overflow: hidden;
        border-radius: 16px;
        transform: rotateY(-8deg) rotateX(4deg) scale(1.05);
        box-shadow: 0 40px 80px rgba(0,0,0, 0.8), 0 0 0 1px rgba(255,255,255,0.05);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        background: #0f0f0f;
    }
    
    .mockup-container:hover {
        transform: rotateY(0) rotateX(0) scale(1.08);
    }

    .mockup-header {
        height: 36px;
        background: rgba(255,255,255,0.02);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        padding: 0 1rem;
        gap: 0.5rem;
    }
    
    .window-controls {
        display: flex;
        gap: 6px;
    }
    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }
    .dot.red { background: #FF5F56; }
    .dot.yellow { background: #FFBD2E; }
    .dot.green { background: #27C93F; }

    .ds-text {
        flex: 1;
        text-align: center;
        font-family: monospace;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.2);
    }

    .mockup-body {
        display: flex;
        height: 360px;
    }

    .sidebar {
        width: 60px;
        border-right: 1px solid rgba(255,255,255,0.05);
        padding: 1rem 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .skeleton-line {
        height: 6px;
        background: rgba(255,255,255,0.05);
        border-radius: 3px;
        width: 100%;
    }
    .skeleton-line.title {
        height: 12px;
        width: 80%;
        margin-bottom: 1rem;
        background: rgba(201, 162, 77, 0.3);
    }

    .main-content {
        flex: 1;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        background: rgba(0,0,0,0.1);
    }

    .top-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .mockup-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 8px;
        padding: 1.25rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .card-title {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-value {
        font-weight: 700;
        font-size: 1.5rem;
    }
    .text-success { color: var(--success); }

    .agenda-view {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 8px;
        overflow: hidden;
    }

    .agenda-item {
        display: flex;
        padding: 1rem;
        gap: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .agenda-item:last-child { border: none; }

    .time {
        font-family: monospace;
        font-size: 0.9rem;
        color: var(--primary);
        font-weight: 600;
        padding-top: 2px;
    }

    .details {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .client {
        font-size: 0.95rem;
        font-weight: 600;
        color: white;
    }

    .status {
        font-size: 0.75rem;
        padding: 4px 8px;
        border-radius: 4px;
        display: inline-block;
        width: fit-content;
        font-weight: 600;
    }
    .status-confirmed { background: rgba(39, 174, 96, 0.15); color: var(--success); }
    .status-pending { background: rgba(201, 162, 77, 0.15); color: var(--primary); }

    .glow-effect {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120%;
        height: 120%;
        background: radial-gradient(circle, rgba(201, 162, 77, 0.2) 0%, rgba(0,0,0,0) 60%);
        z-index: 1;
        pointer-events: none;
    }
</style>
