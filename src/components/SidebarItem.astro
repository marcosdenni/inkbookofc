---
interface Props {
  href: string;
  label: string;
  icon: string;
  collapsed?: boolean;
}

const { href, label, icon, collapsed = false } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
const isActive = pathname === href || (href !== '/' && pathname.startsWith(href));
---

<a href={href} class:list={['sidebar-item', { active: isActive, collapsed }]}>
  <div class="icon-wrapper">
    <Fragment set:html={icon} />
  </div>
  <span class="label">{label}</span>
  
  {collapsed && <div class="tooltip">{label}</div>}
</a>

<style>
  .sidebar-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1rem;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 8px;
    transition: all var(--transition-fast);
    position: relative;
    margin: 0.25rem 0.5rem;
    border-left: 3px solid transparent;
  }

  .sidebar-item:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--text);
  }

  .sidebar-item.active {
    background-color: var(--active-bg);
    color: var(--text);
    border-left-color: var(--primary);
  }

  .sidebar-item.active .icon-wrapper {
    color: var(--primary);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .label {
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
    opacity: 1;
    transition: opacity var(--transition-fast);
  }

  .sidebar-item.collapsed {
    justify-content: center;
    padding: 0.875rem;
    margin: 0.25rem 0.75rem;
    border-left: none;
  }

  .sidebar-item.collapsed .label {
    display: none;
  }

  .sidebar-item.collapsed.active {
    box-shadow: inset 0 0 0 1px var(--primary);
  }

  /* Tooltip for collapsed state */
  .tooltip {
    position: absolute;
    left: 100%;
    margin-left: 1rem;
    background: #1A1A1A;
    color: white;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-size: 0.875rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: all var(--transition-fast);
    box-shadow: var(--shadow-sm);
    z-index: 100;
  }

  .sidebar-item.collapsed:hover .tooltip {
    opacity: 1;
    transform: translateX(5px);
  }
</style>
