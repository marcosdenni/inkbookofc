---
/* src/components/CancelPlanModal.astro */
---

<div id="modal-cancel-plan" class="modal-overlay-cancel hidden">
  <div class="modal-content-cancel">
    <div class="modal-header-cancel">
      <h2 style="color: var(--error);">Deseja mesmo cancelar?</h2>
    </div>
    
    <div class="cancel-explanation">
      <p id="cancel-main-text">Você está prestes a cancelar sua assinatura <strong>PRO</strong> e voltar para o plano <strong>GRATUITO</strong>.</p>
      
      <div id="expiration-info" class="expiration-box hidden">
         <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
         <span>Você continuará com acesso PRO até <strong id="expiration-date-text">--/--/----</strong>. Depois disso, sua conta voltará automaticamente ao plano gratuito.</span>
      </div>

      <div class="warning-box">
        <p>Ao cancelar, você perderá acesso imediato a:</p>
        <ul class="loss-list">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Agendamentos ilimitados (limite de 30/mês)
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Automações de WhatsApp (Confirmação e Lembretes)
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Inteligência Artificial para mensagens
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Dashboard completo de métricas
          </li>
        </ul>
      </div>

      <p class="persuasive-text">
        O <strong>Inkbook Pro</strong> foi desenhado para fazer seu estúdio crescer. 
        Muitos tatuadores economizam mais de 10 horas por semana com nossas automações.
      </p>
    </div>

    <div class="modal-footer-cancel">
      <button id="btn-keep-plan" class="btn-keep">Manter meu Plano PRO</button>
      <button id="btn-confirm-cancel" class="btn-cancel-action">Confirmar Cancelamento</button>
    </div>
  </div>
</div>

<style>
  .modal-overlay-cancel {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
  }

  .modal-overlay-cancel:not(.hidden) {
    opacity: 1;
    pointer-events: auto;
  }

  .hidden { display: none !important; }

  .modal-content-cancel {
    background: #141414;
    width: 100%;
    max-width: 500px;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2.5rem;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8);
    transform: scale(0.95);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .modal-overlay-cancel:not(.hidden) .modal-content-cancel {
    transform: scale(1);
  }

  .modal-header-cancel h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .cancel-explanation {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .expiration-box {
    background: rgba(201, 162, 77, 0.1);
    border: 1px solid rgba(201, 162, 77, 0.2);
    border-radius: 12px;
    padding: 1rem;
    margin: 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--primary);
    font-size: 0.9rem;
  }

  .warning-box {
    background: rgba(192, 57, 43, 0.05);
    border: 1px solid rgba(192, 57, 43, 0.2);
    border-radius: 16px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .warning-box p {
    color: var(--error);
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 1rem;
  }

  .loss-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .loss-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #eee;
  }

  .loss-list svg {
    color: var(--error);
    flex-shrink: 0;
  }

  .persuasive-text {
    text-align: center;
    font-size: 1rem;
    font-style: italic;
    color: var(--text-muted);
  }

  .modal-footer-cancel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-keep {
    width: 100%;
    background: var(--primary);
    color: #000;
    border: none;
    padding: 1.25rem;
    border-radius: 16px;
    font-weight: 800;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .btn-keep:hover {
    transform: scale(1.02);
    filter: brightness(1.1);
    box-shadow: 0 10px 20px rgba(201, 162, 77, 0.2);
  }

  .btn-cancel-action {
    width: 100%;
    background: transparent;
    color: #888;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem;
    border-radius: 16px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .btn-cancel-action:hover {
    color: var(--error);
    border-color: var(--error);
    background: rgba(192, 57, 43, 0.05);
  }
</style>

<script>
  import { supabase } from '../lib/supabase';

  const modal = document.getElementById('modal-cancel-plan');
  const keepBtn = document.getElementById('btn-keep-plan');
  const confirmBtn = document.getElementById('btn-confirm-cancel');

  function closeModal() {
    modal?.classList.add('hidden');
  }

  keepBtn?.addEventListener('click', closeModal);

  confirmBtn?.addEventListener('click', async () => {
    if (!currentSubscriptionData.estudioId) return;

    const originalText = confirmBtn.innerText;
    confirmBtn.setAttribute('disabled', 'true');
    confirmBtn.innerText = 'Processando...';

    try {
      // 1) Obter dados do usuário/estúdio
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) throw new Error('Usuário não autenticado');

      const { data: userData } = await supabase
        .from('users')
        .select('estudio_id')
        .eq('id', user.id)
        .single();

      if (!userData?.estudio_id) throw new Error('Estúdio não localizado');

      const { data: studioData } = await supabase
        .from('estudios')
        .select('id, nome, email')
        .eq('id', userData.estudio_id)
        .single();

      // 2) Chamar o Endpoint Interno de cancelamento
      const response = await fetch('/api/cancel-subscription', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          estudio_id: currentSubscriptionData.estudioId,
          asaas_subscription_id: currentSubscriptionData.subscriptionId,
          data_vencimento: currentSubscriptionData.expirationDate
        })
      });

      if (!response.ok) throw new Error('Erro ao processar cancelamento. Tente novamente em instantes.');

      // @ts-ignore
      if (window.showToast) {
        window.showToast('Solicitação de cancelamento enviada. Você será notificado por e-mail.', 'success');
      }

      closeModal();
      
      // Opcional: Recarregar a página para atualizar o estado do plano se o webhook for síncrono ou disparar um evento
      setTimeout(() => window.location.reload(), 2000);

    } catch (err: any) {
      console.error('Erro ao cancelar:', err);
      // @ts-ignore
      if (window.showToast) window.showToast(err.message, 'error');
    } finally {
      confirmBtn.removeAttribute('disabled');
      confirmBtn.innerText = originalText;
    }
  });

  let currentSubscriptionData = {
    estudioId: '',
    subscriptionId: '',
    expirationDate: ''
  };

  // Escuta evento para abrir
  window.addEventListener('open-cancel-plan-modal', async (e: any) => {
    const { expirationDate, subscriptionId } = e.detail || {};
    const infoBox = document.getElementById('expiration-info');
    const dateText = document.getElementById('expiration-date-text');

    // Salvar dados atuais para o confirm
    const { data: { user } } = await supabase.auth.getUser();
    if (user) {
      const { data: userData } = await supabase
        .from('users')
        .select('estudio_id')
        .eq('id', user.id)
        .single();
      
      currentSubscriptionData.estudioId = userData?.estudio_id || '';
      currentSubscriptionData.subscriptionId = subscriptionId || '';
      currentSubscriptionData.expirationDate = expirationDate || '';
    }

    if (expirationDate) {
      if (dateText) {
        // Formatar data YYYY-MM-DD para DD/MM/YYYY
        const [year, month, day] = expirationDate.split('-');
        dateText.innerText = `${day}/${month}/${year}`;
      }
      infoBox?.classList.remove('hidden');
    } else {
      infoBox?.classList.add('hidden');
    }

    modal?.classList.remove('hidden');
  });
</script>
