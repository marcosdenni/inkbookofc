---
/* src/components/ProPlanModal.astro */
---

<div id="modal-pro-plan" class="modal-overlay-pro hidden">
  <div class="modal-content-pro">
    <div class="modal-header-pro">
      <div class="pro-icon-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <h2 id="pro-modal-title">Controle Financeiro Pro</h2>
    </div>
    
    <div class="pro-explanation">
      <p id="pro-modal-message">Quer ter controle total do seu financeiro e ver todas as métricas do seu estúdio? Assine o Plano Pro e profissionalize sua gestão.</p>
      
      <div class="pro-benefits-box">
        <p class="benefits-label">O QUE VOCÊ TERÁ NO PRO:</p>
        <ul class="benefits-list">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Dashboard Financeiro Completo</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Automações de WhatsApp Ilimitadas</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Agendamentos Ilimitados</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="modal-footer-pro">
      <button id="btn-go-pro" class="btn-upgrade-pro">Quero ser Pro agora</button>
      <button id="btn-close-pro" class="btn-secondary-pro">Agora não</button>
    </div>
  </div>
</div>

<style>
  .modal-overlay-pro {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(10px);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .modal-overlay-pro:not(.hidden) {
    opacity: 1;
    pointer-events: auto;
  }

  .hidden { display: none !important; }

  .modal-content-pro {
    background: linear-gradient(135deg, #141414 0%, #0a0a0a 100%);
    width: 100%;
    max-width: 480px;
    border-radius: 32px;
    border: 1px solid rgba(201, 162, 77, 0.2);
    padding: 3rem 2.5rem;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.9), 0 0 40px rgba(201, 162, 77, 0.05);
    transform: translateY(20px);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: center;
  }

  .modal-overlay-pro:not(.hidden) .modal-content-pro {
    transform: translateY(0);
  }

  .pro-icon-badge {
    width: 70px;
    height: 70px;
    background: rgba(201, 162, 77, 0.1);
    border: 1px solid rgba(201, 162, 77, 0.3);
    border-radius: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    margin: 0 auto 1.5rem;
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
  }

  .modal-header-pro h2 {
    font-size: 2.2rem;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 1px;
    color: #fff;
    margin-bottom: 1rem;
  }

  .pro-explanation {
    color: #bbb;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    font-size: 1.05rem;
  }

  .pro-benefits-box {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 20px;
    padding: 1.5rem;
    margin-top: 2rem;
    text-align: left;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .benefits-label {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: 1.5px;
    margin-bottom: 1rem;
    display: block;
  }

  .benefits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .benefits-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: #eee;
    font-weight: 600;
  }

  .benefits-list svg {
    color: var(--primary);
    flex-shrink: 0;
  }

  .modal-footer-pro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-upgrade-pro {
    width: 100%;
    background: linear-gradient(135deg, var(--primary) 0%, #e5c07b 100%);
    color: #000;
    border: none;
    padding: 1.25rem;
    border-radius: 18px;
    font-weight: 800;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--font-text);
  }

  .btn-upgrade-pro:hover {
    transform: scale(1.03);
    box-shadow: 0 15px 30px rgba(201, 162, 77, 0.3);
    filter: brightness(1.1);
  }

  .btn-secondary-pro {
    width: 100%;
    background: transparent;
    color: #666;
    border: none;
    padding: 0.75rem;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .btn-secondary-pro:hover {
    color: #fff;
  }
</style>

<script>
  const modal = document.getElementById('modal-pro-plan');
  const closeBtn = document.getElementById('btn-close-pro');
  const upgradeBtn = document.getElementById('btn-go-pro');

  function closeModal() {
    modal?.classList.add('hidden');
  }

  closeBtn?.addEventListener('click', closeModal);

  upgradeBtn?.addEventListener('click', () => {
    window.location.href = '/assinatura';
  });

  // Escuta evento para abrir
  window.addEventListener('open-pro-plan-modal', (e: any) => {
    const { title, message } = e.detail || {};
    
    if (title) {
        const titleEl = document.getElementById('pro-modal-title');
        if (titleEl) titleEl.innerText = title;
    }
    
    if (message) {
        const messageEl = document.getElementById('pro-modal-message');
        if (messageEl) messageEl.innerText = message;
    }

    modal?.classList.remove('hidden');
  });

  // Fechar ao clicar fora
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
</script>
