  function updateCustomDropdown(id: string, items: any[], placeholder: string) {
    const container = document.getElementById(`${id}-custom-container`);
    const trigger = document.getElementById(`${id}-trigger`);
    const optionsList = document.getElementById(`${id}-options`);
    const nativeSelect = document.getElementById(id) as HTMLSelectElement;
    const triggerText = trigger?.querySelector('.trigger-text');

    if (!container || !trigger || !optionsList || !nativeSelect || !triggerText) return;

    // 1. Sincronizar Select Nativo
    nativeSelect.innerHTML = `<option value="">${placeholder}</option>` + 
      items.map(item => `<option value="${item.id}">${item.nome}</option>`).join('');

    // 2. Sincronizar UI do Trigger Inicial
    if (nativeSelect.value) {
      const selected = items.find(i => i.id === nativeSelect.value);
      if (selected && triggerText) {
        triggerText.textContent = selected.nome;
        trigger.classList.remove('placeholder');
      }
    } else {
      triggerText.textContent = placeholder;
      trigger.classList.add('placeholder');
    }

    // 3. Renderizar Opções Customizadas
    renderOptions(optionsList, items, nativeSelect.value);

    // 4. Configurar Trigger (APENAS UMA VEZ)
    if (!trigger.dataset.initialized) {
      trigger.dataset.initialized = 'true';
      trigger.addEventListener('click', (e: Event) => {
        e.stopPropagation();
        const isOpen = container.classList.contains('open');
        closeAllDropdowns();
        if (!isOpen) container.classList.add('open');
      });

      // 5. Lógica de Seleção (Delegação de Evento)
      optionsList.addEventListener('click', (e: Event) => {
        const target = e.target as HTMLElement;
        const option = target.closest('.custom-option') as HTMLElement;
        if (!option) return;

        e.stopPropagation();
        const value = option.dataset.value || '';
        const name = option.textContent?.trim() || '';

        // Atualizar Select Nativo
        nativeSelect.value = value;
        nativeSelect.dispatchEvent(new Event('change', { bubbles: true }));

        // Atualizar UI do Trigger
        triggerText.textContent = name;
        trigger.classList.remove('placeholder');

        // Marcar selecionado visualmente
        const allOpts = optionsList.querySelectorAll('.custom-option');
        allOpts.forEach(o => o.classList.remove('selected'));
        option.classList.add('selected');

        // Fechar
        container.classList.remove('open');
      });
    }
}

  function renderOptions(optionsList: HTMLElement, items: any[], selectedValue: string) {
    optionsList.innerHTML = items.map(item => `
      <div class="custom-option ${selectedValue === item.id ? 'selected' : ''}" data-value="${item.id}">
        ${item.nome}
      </div>
    `).join('');
  }

  function closeAllDropdowns(exceptId?: string) {
    document.querySelectorAll('.custom-select-container').forEach(container => {
