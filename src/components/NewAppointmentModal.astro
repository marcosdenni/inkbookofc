  const dropzone = document.getElementById('upload-dropzone');
  const fileInput = document.getElementById('referencias-input') as HTMLInputElement;
  const previewContainer = document.getElementById('preview-container');
  let selectedFiles: File[] = [];
  let existingReferences: any[] = [];

  // Dropzone events
  dropzone?.addEventListener('click', () => fileInput.click());

  fileInput?.addEventListener('change', () => {
    if (fileInput.files) {
      handleFiles(Array.from(fileInput.files));
    }
  });

  function handleFiles(files: File[]) {
    const validFiles = files.filter(file => {
      if (!file.type.startsWith('image/')) {
        alert(`${file.name} não é uma imagem válida.`);
        return false;
      }
      if (file.size > 5 * 1024 * 1024) {
        alert(`${file.name} excede o limite de 5MB.`);
        return false;
      }
      return true;
    });

    selectedFiles = [...selectedFiles, ...validFiles];
    renderPreviews();
  }

  function renderPreviews() {
    if (!previewContainer) return;
    previewContainer.innerHTML = '';
    
    const deleteIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>`;

    // 1. Renderizar imagens já no servidor (se houver)
    existingReferences.forEach((ref) => {
      const { data } = supabase.storage.from('referencias').getPublicUrl(ref.storage_path);
      const publicUrl = data.publicUrl;
      const div = document.createElement('div');
      div.className = 'preview-item existing';
      div.innerHTML = `
        <img src="${publicUrl}" alt="Ref" />
        <button type="button" class="remove-preview delete-existing" data-id="${ref.id}" data-path="${ref.storage_path}" title="Excluir Referência">${deleteIcon}</button>
      `;
      div.onclick = (e) => {
        if ((e.target as HTMLElement).closest('.remove-preview')) return;
        openZoom(publicUrl);
      };
      previewContainer.appendChild(div);
    });

    // 2. Renderizar novas imagens selecionadas
    selectedFiles.forEach((file, index) => {
      const url = URL.createObjectURL(file);
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.innerHTML = `
        <img src="${url}" alt="Preview" />
        <button type="button" class="remove-preview delete-new" data-index="${index}" title="Remover">${deleteIcon}</button>
      `;
      div.onclick = (e) => {
        if ((e.target as HTMLElement).closest('.remove-preview')) return;
        openZoom(url);
      };
      previewContainer.appendChild(div);
    });

    // Listeners para novas imagens
    document.querySelectorAll('.delete-new').forEach(btn => {
      btn.onclick = (e) => {
        e.stopPropagation();
        const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
        selectedFiles.splice(index, 1);
        renderPreviews();
      };
    });

    // Listeners para imagens existentes
    document.querySelectorAll('.delete-existing').forEach(btn => {
        btn.onclick = async (e) => {
            e.stopPropagation();
            const btnEl = e.currentTarget as HTMLButtonElement;
            const refId = btnEl.dataset.id;
            const refPath = btnEl.dataset.path;
            
            if (!confirm('Deseja excluir permanentemente esta referência?')) return;

            // 1. Deletar do banco
            const { error: dbError } = await supabase.from('agendamento_referencias').delete().eq('id', refId);
            if (dbError) { alert('Erro ao excluir do banco.'); return; }

            // 2. Deletar do storage
            if (refPath) {
                await supabase.storage.from('referencias').remove([refPath]);
            }

            // 3. Atualizar localmente
            existingReferences = existingReferences.filter(r => r.id !== refId);
            renderPreviews();
        };
    });
  }

  function openZoom(url: string) {
    const zoomModal = document.getElementById('modal-zoom');
    const zoomImg = document.getElementById('zoom-img') as HTMLImageElement;
    if (zoomModal && zoomImg) {
      zoomImg.src = url;
      zoomModal.classList.remove('hidden');
    }
  }

  document.getElementById('close-zoom')?.addEventListener('click', () => {
    document.getElementById('modal-zoom')?.classList.add('hidden');
  });

  // Session calculation logic
  const inputData = document.getElementById('data') as HTMLInputElement;
  const inputHora = document.getElementById('hora') as HTMLInputElement;
  const inputDuracao = document.getElementById('duracao') as HTMLInputElement;
  const inputHoraFim = document.getElementById('hora_fim') as HTMLInputElement;
  const sessionSummary = document.getElementById('session-summary');
  const summaryStart = document.getElementById('summary-start');
  const summaryEnd = document.getElementById('summary-end');
  const summaryDuration = document.getElementById('summary-duration');

  function updateEndTime() {
    if (!inputHora.value || !inputDuracao.value) {
      inputHoraFim.value = "";
      sessionSummary?.classList.add('hidden');
      return;
    }

    const [hours, minutes] = inputHora.value.split(':').map(Number);
    const duracao = parseInt(inputDuracao.value);
    
    const startTime = new Date();
    startTime.setHours(hours, minutes, 0);
    
    const endTime = new Date(startTime.getTime() + duracao * 60000);
    
    const endHours = String(endTime.getHours()).padStart(2, '0');
    const endMinutes = String(endTime.getMinutes()).padStart(2, '0');
    
    const formattedEndTime = `${endHours}:${endMinutes}`;
    inputHoraFim.value = formattedEndTime;

    // Update summary
    if (sessionSummary && summaryStart && summaryEnd && summaryDuration) {
      sessionSummary.classList.remove('hidden');
      summaryStart.innerText = inputHora.value;
      summaryEnd.innerText = formattedEndTime;
      
      const hoursCount = Math.floor(duracao / 60);
      const minsCount = duracao % 60;
      summaryDuration.innerText = `${hoursCount}h${minsCount > 0 ? ` ${minsCount}m` : ''}`;
    }
  }

  inputHora?.addEventListener('input', updateEndTime);
  inputDuracao?.addEventListener('input', updateEndTime);

  // Financial validation
  const inputTotal = document.getElementById('valor_total') as HTMLInputElement;
  const inputSinal = document.getElementById('valor_sinal') as HTMLInputElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validations
    const total = parseFloat(inputTotal.value || '0');
    const sinal = parseFloat(inputSinal.value || '0');
    const duracao = parseInt(inputDuracao.value || '0');

    if (duracao <= 0) {
      alert('A duração deve ser maior que 0 minutos.');
      return;
    }

        if (sinal > total) {
      alert('O valor do sinal não pode ser maior que o valor total.');
      return;
    }

    const saveBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = saveBtn.innerText;
    
    try {
      saveBtn.disabled = true;
      saveBtn.innerText = 'Salvando...';

      const formData = new FormData(form);
      
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) throw new Error('Usuário não autenticado');

      const { data: profile } = await supabase
        .from('users')
        .select('estudio_id')
        .eq('id', user.id)
        .single();

      if (!profile) throw new Error('Perfil não encontrado');

      const editingId = (document.getElementById('editing-id') as HTMLInputElement).value;
      
      // --- LÓGICA FINANCEIRA ---
      const tatuador_id = formData.get('tatuador_id') as string;
      const valor_total = parseFloat(formData.get('valor_total') as string || '0');
      
      let valor_estudio = 0;
      let valor_tatuador = valor_total;

      if (tatuador_id) {
        // 1. Buscar dados do tatuador
        const { data: tatuador } = await supabase
          .from('tatuadores')
          .select('*, estudio:estudios(id)')
          .eq('id', tatuador_id)
          .single();

        if (tatuador) {
          let configFinanceira;
          
          if (tatuador.usa_modelo_padrao) {
            // 2. Buscar config padrão do estúdio
            const { data: configPadrao } = await supabase
              .from('configuracoes_financeiras')
              .select('*')
              .eq('estudio_id', profile.estudio_id)
              .single();
            
            configFinanceira = configPadrao ? {
              modelo: configPadrao.modelo_pagamento_padrao,
              percent_estudio: configPadrao.percentual_estudio_padrao,
              percent_tatuador: configPadrao.percentual_tatuador_padrao
            } : null;
          } else {
            configFinanceira = {
              modelo: tatuador.modelo_pagamento,
              percent_estudio: tatuador.percentual_estudio,
              percent_tatuador: tatuador.percentual_tatuador
            };
          }

          // 3. Aplicar Cálculo
          if (configFinanceira) {
            const modelo = configFinanceira.modelo || 'percentual';
            
            if (modelo === 'percentual' || modelo === 'hibrido') {
              const pEstudio = Number(configFinanceira.percent_estudio) || 0;
              const pTatuador = Number(configFinanceira.percent_tatuador) || 100;
              
              valor_estudio = (valor_total * pEstudio) / 100;
              valor_tatuador = (valor_total * pTatuador) / 100;
            } else if (modelo === 'aluguel_fixo') {
              valor_estudio = 0;
              valor_tatuador = valor_total;
            }
          }
        }
      }

      // 4. Salvar Agendamento
      const dataStr = formData.get('data') as string;
      const horaStr = formData.get('hora') as string;
      
      // Calcular data_hora_fim para o banco
      const dur = parseInt(formData.get('duracao_minutos') as string);
      const dInicio = new Date(`${dataStr}T${horaStr}:00`);
      const dFim = new Date(dInicio.getTime() + dur * 60000);

      const appointmentData = {
        cliente_id: formData.get('cliente_id'),
        tatuador_id: formData.get('tatuador_id'),
        data_hora: dInicio.toISOString(),
        data_hora_fim: dFim.toISOString(),
        duracao_minutos: dur,
        valor_total: valor_total,
        valor_sinal: parseFloat(formData.get('valor_sinal') as string || '0'),
        valor_estudio: valor_estudio,
        valor_tatuador: valor_tatuador,
        pago: formData.get('pago') === 'on',
        sinal_pago: formData.get('sinal_pago') === 'on',
        estudio_id: profile.estudio_id,
        status: formData.get('status') || 'Pendente'
      };

      // --- VALIDAÇÃO DE SOBREPOSIÇÃO (MESMO TATUADOR) ---
      if (appointmentData.tatuador_id) {
        // Buscar agendamentos do mesmo tatuador no mesmo dia
        const startOfDay = new Date(dataStr + 'T00:00:00Z').toISOString();
        const endOfDay = new Date(dataStr + 'T23:59:59Z').toISOString();

        let query = supabase
          .from('agendamentos')
          .select('id, data_hora, data_hora_fim, status')
          .eq('tatuador_id', appointmentData.tatuador_id)
          .neq('status', 'Cancelado') // Ignorar cancelados
          .gte('data_hora', startOfDay)
          .lte('data_hora', endOfDay);
        
        if (editingId) {
          query = query.neq('id', editingId);
        }

        const { data: conflicts, error: conflictError } = await query;

        if (conflictError) throw conflictError;

        const hasOverlap = conflicts?.some(existing => {
          const exStart = new Date(existing.data_hora).getTime();
          const exEnd = new Date(existing.data_hora_fim).getTime();
          const newStart = dInicio.getTime();
          const newEnd = dFim.getTime();

          return (newStart < exEnd) && (newEnd > exStart);
        });

        if (hasOverlap) {
          alert('Conflito de Horário! Este tatuador já possui um agendamento que se sobrepõe ao horário selecionado.');
          saveBtn.disabled = false;
          saveBtn.innerText = originalText;
          return;
        }
      }

      let newAppointmentId = '';

      if (editingId) {
        const { data: updatedAppt, error: appError } = await supabase
          .from('agendamentos')
          .update(appointmentData)
          .eq('id', editingId)
          .select()
          .single();
        
        if (appError) throw appError;
        newAppointmentId = editingId;
      } else {
        const { data: newAppointment, error: appError } = await supabase
          .from('agendamentos')
          .insert([appointmentData])
          .select()
          .single();

        if (appError) throw appError;
        newAppointmentId = newAppointment.id;
        
        // DISPARAR NOTIFICAÇÃO WHATSAPP (Aguardar disparo antes do reload)
        await sendWhatsAppConfirmation(newAppointmentId, profile.estudio_id);
      }

      // 2. Upload das imagens
      if (selectedFiles.length > 0) {
        saveBtn.innerText = 'Enviando imagens...';
        
        for (const file of selectedFiles) {
          const fileExt = file.name.split('.').pop() || 'jpg';
          const fileName = `${crypto.randomUUID()}.${fileExt}`;
          const storagePath = `${profile.estudio_id}/${newAppointmentId}/${fileName}`;

          const { error: uploadError } = await supabase.storage
            .from('referencias')
            .upload(storagePath, file);

          if (uploadError) {
            console.error('Erro no upload:', uploadError);
            continue;
          }

          // 3. Salvar referência no banco
          await supabase
            .from('agendamento_referencias')
            .insert({
              agendamento_id: newAppointmentId,
              storage_path: storagePath
            });
        }
      }

      closeModal();
      window.dispatchEvent(new CustomEvent('appointment-saved'));
      // Só recarrega se não estiver na agenda (agenda usa event-driven)
      if (!window.location.pathname.includes('/agenda')) {
        window.location.reload();
      }
    } catch (err: any) {
      alert('Erro inesperado: ' + err.message);
      saveBtn.disabled = false;
      saveBtn.innerText = originalText;
    }
  });

  // Listen for open event (suporta pré-preenchimento de data/hora pela Agenda)
  window.addEventListener('open-new-appointment-modal', async (e: any) => {
    await loadFormData(); 
    modal?.classList.remove('hidden');

    const { date, time, appointment } = e.detail || {};

    selectedFiles = [];
    existingReferences = [];
    renderPreviews();

    // Resetar botão de salvar ao abrir
    const saveBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (saveBtn) {
      saveBtn.disabled = false;
      saveBtn.innerText = 'Salvar Agendamento';
    }

    if (appointment) {
      // MODO EDIÇÃO
      const modalTitle = modal?.querySelector('h2');
      if (modalTitle) modalTitle.innerText = 'Editar Agendamento';

      (document.getElementById('editing-id') as HTMLInputElement).value = appointment.id;
      
      // Carregar referências existentes
      const { data: refs } = await supabase.from('agendamento_referencias').select('*').eq('agendamento_id', appointment.id);
      if (refs) {
        existingReferences = refs;
        renderPreviews();
      }

      // Preencher cliente e sincronizar dropdown customizado
      if (appointment.cliente_id) {
        const nativeSelect = document.getElementById('cliente') as HTMLSelectElement;
        const trigger = document.getElementById('cliente-trigger');
        const triggerText = trigger?.querySelector('.trigger-text');
        const optionsList = document.getElementById('cliente-options');
        
        nativeSelect.value = appointment.cliente_id;
        if (triggerText) {
          triggerText.textContent = appointment.cliente?.nome || 'Cliente Selecionado';
          trigger?.classList.remove('placeholder');
        }
        // Sincronizar visualmente as opções
        if (optionsList) {
          const options = optionsList.querySelectorAll('.custom-option');
          options.forEach(opt => {
            if ((opt as HTMLElement).dataset.value === appointment.cliente_id) {
              opt.classList.add('selected');
            } else {
              opt.classList.remove('selected');
            }
          });
        }
      }

      // Preencher tatuador e sincronizar dropdown customizado
      if (appointment.tatuador_id) {
        const nativeSelect = document.getElementById('tatuador') as HTMLSelectElement;
        const trigger = document.getElementById('tatuador-trigger');
        const triggerText = trigger?.querySelector('.trigger-text');
        const optionsList = document.getElementById('tatuador-options');
        
        nativeSelect.value = appointment.tatuador_id;
        if (triggerText) {
          triggerText.textContent = appointment.tatuador?.nome || 'Tatuador Selecionado';
          trigger?.classList.remove('placeholder');
        }
        // Sincronizar visualmente as opções
        if (optionsList) {
          const options = optionsList.querySelectorAll('.custom-option');
          options.forEach(opt => {
            if ((opt as HTMLElement).dataset.value === appointment.tatuador_id) {
              opt.classList.add('selected');
            } else {
              opt.classList.remove('selected');
            }
          });
        }
      }

      const dt = new Date(appointment.data_hora);
      (document.getElementById('data') as HTMLInputElement).value = dt.getFullYear() + '-' + String(dt.getMonth() + 1).padStart(2, '0') + '-' + String(dt.getDate()).padStart(2, '0');
      (document.getElementById('hora') as HTMLInputElement).value = String(dt.getHours()).padStart(2, '0') + ':' + String(dt.getMinutes()).padStart(2, '0');
      (document.getElementById('duracao') as HTMLInputElement).value = appointment.duracao_minutos || 60;
      (document.getElementById('valor_total') as HTMLInputElement).value = appointment.valor_total || 0;
      (document.getElementById('valor_sinal') as HTMLInputElement).value = appointment.valor_sinal || 0;
      (document.getElementById('pago') as HTMLInputElement).checked = !!appointment.pago;
      (document.getElementById('sinal_pago') as HTMLInputElement).checked = !!appointment.sinal_pago;
      
      const statuses = [
        { id: 'Pendente', nome: 'Pendente' },
        { id: 'Confirmado', nome: 'Confirmado' },
        { id: 'Realizado', nome: 'Realizado' },
        { id: 'Cancelado', nome: 'Cancelado' },
        { id: 'Falta', nome: 'Falta' }
      ];

      // Preencher status
      if (appointment.status) {
        const nativeSelect = document.getElementById('status') as HTMLSelectElement;
        const trigger = document.getElementById('status-trigger');
        const triggerText = trigger?.querySelector('.trigger-text');
        const optionsList = document.getElementById('status-options');
        
        nativeSelect.value = appointment.status;
        if (triggerText) {
          triggerText.textContent = appointment.status;
          trigger?.classList.remove('placeholder');
        }
        if (optionsList) {
          renderOptions(optionsList, statuses, appointment.status);
        }
      }
    } else {
      // MODO NOVO
      const statusInfo = document.getElementById('whatsapp-status-info');
      if (statusInfo) {
        statusInfo.classList.add('hidden');
        statusInfo.innerHTML = '';
      }
      
      const modalTitle = modal?.querySelector('h2');
      if (modalTitle) modalTitle.innerText = 'Novo Agendamento';
      (document.getElementById('editing-id') as HTMLInputElement).value = '';

      if (date) {
        const dataEl = document.getElementById('data') as HTMLInputElement;
        if (dataEl) dataEl.value = date;
      }
      if (time) {
        const horaEl = document.getElementById('hora') as HTMLInputElement;
        if (horaEl) { horaEl.value = time; }
      }
      
      const statuses = [
        { id: 'Pendente', nome: 'Pendente' },
        { id: 'Confirmado', nome: 'Confirmado' },
        { id: 'Cancelado', nome: 'Cancelado' },
        { id: 'Falta', nome: 'Falta' }
      ];
      
      const nativeSelect = document.getElementById('status') as HTMLSelectElement;
      const trigger = document.getElementById('status-trigger');
      const triggerText = trigger?.querySelector('.trigger-text');
      const optionsList = document.getElementById('status-options');
      
      nativeSelect.value = 'Pendente';
      if (triggerText) {
        triggerText.textContent = 'Pendente';
        trigger?.classList.remove('placeholder');
      }
      if (optionsList) {
        renderOptions(optionsList, statuses, 'Pendente');
      }
    }
    
    // Atualizar horário final
    updateEndTime();
  });
</script>
