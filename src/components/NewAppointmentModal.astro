---
interface Props {
  clientes: { id: string; nome: string }[];
  tatuadores: { id: string; nome: string }[];
}

const { clientes, tatuadores } = Astro.props;
---

<div id="new-appointment-modal" class="modal-overlay hidden">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modal-title">Novo Agendamento</h2>
      <button id="close-modal" class="close-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <form id="new-appointment-form" class="appointment-form">
      <input type="hidden" id="editing-id" name="id" />
      <div class="form-grid">
        <div class="form-group">
          <div class="label-header">
            <label for="cliente">Cliente</label>
            <button type="button" id="btn-add-new-client" class="btn-text-action">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Novo cliente
            </button>
          </div>
          <div class="custom-select-container" id="cliente-custom-container">
            <button type="button" class="custom-select-trigger" id="cliente-trigger">
              <span class="trigger-text">Selecione um cliente</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="custom-options" id="cliente-options">
              <!-- Opções serão inseridas via JS -->
            </div>
            <select id="cliente" name="cliente_id" required class="hidden-native-select">
              <option value="">Selecione um cliente</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="tatuador">Tatuador</label>
          <div class="custom-select-container" id="tatuador-custom-container">
            <button type="button" class="custom-select-trigger" id="tatuador-trigger">
              <span class="trigger-text">Selecione um tatuador</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="custom-options" id="tatuador-options">
              <!-- Opções serão inseridas via JS -->
            </div>
            <select id="tatuador" name="tatuador_id" required class="hidden-native-select">
              <option value="">Selecione um tatuador</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="data">Data</label>
          <input type="date" id="data" name="data" required />
        </div>

        <div class="form-group">
          <label for="hora">Hora</label>
          <input type="time" id="hora" name="hora" required />
        </div>

        <div class="form-group">
          <label for="duracao">Duração (minutos)</label>
          <input type="number" id="duracao" name="duracao_minutos" min="1" value="60" required />
        </div>

        <div class="form-group">
          <label for="hora_fim">Horário Final (calculado)</label>
          <input type="time" id="hora_fim" readonly class="readonly-input" />
        </div>
      </div>

      <div id="session-summary" class="session-summary hidden">
        <div class="summary-item">
          <span class="label">Início:</span>
          <span id="summary-start" class="value">-</span>
        </div>
        <div class="summary-item">
          <span class="label">Fim:</span>
          <span id="summary-end" class="value">-</span>
        </div>
        <div class="summary-item">
          <span class="label">Duração:</span>
          <span id="summary-duration" class="value">-</span>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label for="valor_total">Valor Total (R$)</label>
          <input type="number" id="valor_total" name="valor_total" step="0.01" min="0" placeholder="0,00" required />
        </div>

        <div class="form-group">
          <label for="valor_sinal">Valor Sinal (R$)</label>
          <input type="number" id="valor_sinal" name="valor_sinal" step="0.01" min="0" placeholder="0,00" />
        </div>

        <div class="form-group flex-row">
          <label class="checkbox-label">
            <input type="checkbox" name="sinal_pago" id="sinal_pago">
            <span>Sinal pago</span>
          </label>
        </div>

        <div class="form-group flex-row">
          <label class="checkbox-label">
            <input type="checkbox" name="pago" id="pago">
            <span>Tatuagem paga</span>
          </label>
        </div>

        <div class="form-group full-width">
          <label for="status">Status do Agendamento</label>
          <div class="custom-select-container" id="status-custom-container">
            <button type="button" class="custom-select-trigger" id="status-trigger">
              <span class="trigger-text">Pendente</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="custom-options" id="status-options">
              <!-- Opções serão inseridas via JS -->
            </div>
            <select id="status" name="status" required class="hidden-native-select">
              <option value="Pendente">Pendente</option>
              <option value="Confirmado">Confirmado</option>
              <option value="Realizado">Realizado</option>
              <option value="Cancelado">Cancelado</option>
              <option value="Falta">Falta</option>
            </select>
          </div>
        </div>

      <div class="form-group full-width">
        <label>Referências Visuais (Imagens)</label>
        <div class="upload-container" id="upload-dropzone">
          <input type="file" id="referencias-input" name="referencias_files" accept="image/*" multiple class="hidden-input" />
          <div class="upload-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <p>Clique ou arraste imagens para upload</p>
            <span>Máximo 5MB por imagem</span>
          </div>
        </div>
        <div id="preview-container" class="preview-container"></div>
      </div>
      </div>

      <div class="modal-footer">
        <button type="button" id="cancel-btn" class="btn-secondary">Cancelar</button>
        <button type="submit" class="btn-primary">Salvar Agendamento</button>
      </div>
    </form>
  </div>
</div>

<!-- LIGHTBOX PARA ZOOM -->
<div id="modal-zoom" class="modal-overlay hidden" style="z-index: 9999; background: rgba(0,0,0,0.95); position: fixed; inset: 0;">
  <div class="zoom-content">
    <img id="zoom-img" src="" alt="Zoom" />
    <button type="button" id="close-zoom" class="close-zoom">&times;</button>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .modal-overlay:not(.hidden) {
    opacity: 1;
    pointer-events: auto;
  }

  .hidden {
    display: none;
  }

  .modal-content {
    background-color: #121212;
    width: 100%;
    max-width: 600px;
    max-height: 90vh;
    overflow-y: auto;
    overflow-x: hidden;
    border-radius: 24px;
    border: 1px solid rgba(201, 162, 77, 0.2);
    padding: 2rem;
    box-sizing: border-box;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: translateY(20px);
    transition: transform 0.3s ease;
    scrollbar-width: thin;
    scrollbar-color: var(--primary) transparent;
  }

  .modal-content::-webkit-scrollbar {
    width: 6px;
  }

  .modal-content::-webkit-scrollbar-track {
    background: transparent;
  }

  .modal-content::-webkit-scrollbar-thumb {
    background-color: var(--primary);
    border-radius: 20px;
  }

  .modal-overlay:not(.hidden) .modal-content {
    transform: translateY(0);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .modal-header h2 {
    font-family: 'Urbanist', sans-serif;
    font-size: 1.5rem;
    color: var(--primary);
    margin: 0;
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    transition: all 0.2s ease;
  }

  .close-btn:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--text);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .flex-row {
    flex-direction: row;
    align-items: center;
  }

  .full-width {
    grid-column: span 2;
  }

  .label-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  select, input, textarea {
    color-scheme: dark;
    background-color: #1A1A1A;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: inherit;
    transition: all 0.2s ease;
  }

  select:focus, input:focus, textarea:focus {
    outline: none;
    border-color: var(--primary);
    background-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 0 15px rgba(201, 162, 77, 0.15);
  }

  .custom-select-container {
    position: relative;
    width: 100%;
  }

  .custom-select-trigger {
    width: 100%;
    background-color: #232323;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    color: #F5F5F5;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    text-align: left;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-size: 0.95rem;
  }

  .custom-select-container:focus-within .custom-select-trigger {
    border-color: var(--primary);
    box-shadow: 0 0 15px rgba(201, 162, 77, 0.15);
    background-color: rgba(201, 162, 77, 0.02);
  }

  .custom-select-trigger .trigger-text {
    opacity: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .custom-select-trigger.placeholder .trigger-text {
    opacity: 0.5;
  }

  .custom-select-trigger .chevron {
    color: var(--primary);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .custom-select-container.open .custom-select-trigger .chevron {
    transform: rotate(180deg);
  }

  :global(.custom-options) {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background-color: #2A2A2A;
    border: 1px solid rgba(201, 162, 77, 0.25);
    border-radius: 12px;
    z-index: 1100;
    max-height: 280px;
    overflow-y: auto;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.7);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    scrollbar-width: thin;
    scrollbar-color: var(--primary) transparent;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    pointer-events: all !important;
  }

  :global(.custom-select-container.open .custom-options) {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  :global(.custom-option) {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    min-height: 48px;
    color: #F5F5F5;
    cursor: pointer !important;
    transition: all 150ms ease;
    font-size: 0.95rem;
    border-radius: 8px;
    background-color: transparent;
    user-select: none;
    border: 1px solid transparent;
    border-left: 3px solid transparent;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    z-index: 100;
    pointer-events: auto !important;
  }

  :global(.custom-option:hover) {
    background-color: #3D3D3D !important;
    color: #FFFFFF !important;
    border-left-color: var(--primary) !important;
    transform: translateX(4px);
  }

  :global(.custom-option.selected) {
    background-color: rgba(201, 162, 77, 0.12) !important;
    color: var(--primary) !important;
    border-color: rgba(201, 162, 77, 0.3) !important;
    border-left-color: var(--primary) !important;
    font-weight: 600;
  }

  :global(.custom-option.selected:hover) {
    background-color: rgba(201, 162, 77, 0.2) !important;
    transform: translateX(4px);
  }

  :global(.custom-option.selected::after) {
    content: '';
    width: 8px;
    height: 8px;
    background-color: var(--primary);
    border-radius: 50%;
    margin-left: auto;
    box-shadow: 0 0 12px var(--primary);
    flex-shrink: 0;
  }

  :global(.custom-options::-webkit-scrollbar) {
    width: 4px;
  }

  :global(.custom-options::-webkit-scrollbar-thumb) {
    background-color: var(--primary);
    border-radius: 10px;
  }

  .hidden-native-select {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
    pointer-events: none;
  }

  .readonly-input {
    background-color: rgba(255, 255, 255, 0.01);
    border-color: rgba(255, 255, 255, 0.05);
    color: var(--text);
    cursor: default;
  }

  .session-summary {
    background: rgba(201, 162, 77, 0.05);
    border: 1px solid rgba(201, 162, 77, 0.1);
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    justify-content: space-around;
    margin-bottom: 1.5rem;
  }

  .summary-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .summary-item .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .summary-item .value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--primary);
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.875rem;
    user-select: none;
  }

  .checkbox-label input {
    accent-color: var(--primary);
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .upload-container {
    border: 2px dashed rgba(201, 162, 77, 0.2);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    background-color: rgba(255, 255, 255, 0.02);
  }

  .upload-container:hover {
    border-color: var(--primary);
    background-color: rgba(255, 255, 255, 0.04);
  }

  .hidden-input {
    display: none;
  }

  .upload-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
  }

  .upload-placeholder svg {
    color: var(--primary);
    opacity: 0.8;
  }

  .zoom-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
  }

  .zoom-content img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 8px;
    box-shadow: 0 0 50px rgba(0,0,0,0.5);
  }

  .close-zoom {
    position: absolute;
    top: -40px;
    right: 0;
    background: transparent;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
  }

  .modal-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .btn-primary {
    background-color: var(--primary);
    color: black;
    border: none;
    padding: 0.875rem 2rem;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
    box-shadow: 0 4px 15px rgba(201, 162, 77, 0.2);
  }

  .btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.875rem 1.75rem;
    border-radius: 14px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-text-action {
    background: transparent;
    border: none;
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0;
  }

  .whatsapp-status-info {
    margin-top: 8px;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  :global(.preview-container) {
    display: grid;
    grid-template-columns: repeat(auto-fill, 80px);
    gap: 0.75rem;
    margin-top: 1rem;
  }
  :global(.preview-item) {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.1);
  }
  :global(.preview-item img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  :global(.remove-preview) {
    position: absolute;
    top: 4px;
    right: 4px;
    background: #e74c3c;
    color: white;
    border-radius: 5px;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
    .full-width {
      grid-column: span 1;
    }
  }
</style>

<script>
  import { supabase } from '../lib/supabase';

  const modal = document.getElementById('new-appointment-modal');
  const closeBtn = document.getElementById('close-modal');
  const cancelBtn = document.getElementById('cancel-btn');
  const btnNewClient = document.getElementById('btn-add-new-client');
  const form = document.getElementById('new-appointment-form') as HTMLFormElement;
  const WEBHOOK_N8N = 'https://webhooks-mvp.marcosdev.xyz/webhook/enviar-whatsapp-agendamento';
      
  let clientsList: any[] = [];
  let artistsList: any[] = [];
  const statusList = [
    { id: 'Pendente', nome: 'Pendente' },
    { id: 'Confirmado', nome: 'Confirmado' },
    { id: 'Realizado', nome: 'Realizado' },
    { id: 'Cancelado', nome: 'Cancelado' },
    { id: 'Falta', nome: 'Falta' }
  ];

  function syncDropdownUI(id: string, items: any[]) {
    const container = document.getElementById(`${id}-custom-container`);
    const trigger = document.getElementById(`${id}-trigger`);
    const optionsList = document.getElementById(`${id}-options`);
    const nativeSelect = document.getElementById(id) as HTMLSelectElement;
    const triggerText = trigger?.querySelector('.trigger-text');

    if (!container || !trigger || !optionsList || !nativeSelect || !triggerText) return;

    if (nativeSelect.value) {
      const selected = items.find(i => i.id === nativeSelect.value);
      if (selected) triggerText.textContent = selected.nome;
    } else {
      const placeholder = nativeSelect.options[0]?.textContent || '';
      triggerText.textContent = placeholder;
    }

    optionsList.innerHTML = items.map(item => `
      <div class="custom-option ${nativeSelect.value === item.id ? 'selected' : ''}" data-value="${item.id}">
        ${item.nome}
      </div>
    `).join('');
  }

  function updateCustomDropdown(id: string, items: any[], placeholder: string) {
    const container = document.getElementById(`${id}-custom-container`);
    const trigger = document.getElementById(`${id}-trigger`);
    const optionsList = document.getElementById(`${id}-options`);
    const nativeSelect = document.getElementById(id) as HTMLSelectElement;

    if (!container || !trigger || !optionsList || !nativeSelect) return;

    nativeSelect.innerHTML = `<option value="">${placeholder}</option>` + 
      items.map(item => `<option value="${item.id}">${item.nome}</option>`).join('');

    // Sincronizar valor padrão se necessário
    if (!nativeSelect.value && items.some(i => i.id === placeholder)) {
      nativeSelect.value = placeholder;
    }

    syncDropdownUI(id, items);

    if (!trigger.dataset.initialized) {
      trigger.dataset.initialized = 'true';
      trigger.onclick = (e) => {
        e.stopPropagation();
        const isOpen = container.classList.contains('open');
        closeAllDropdowns();
        if (!isOpen) container.classList.add('open');
      };

      optionsList.onclick = (e) => {
        const option = (e.target as HTMLElement).closest('.custom-option') as HTMLElement;
        if (!option) return;
        e.stopPropagation();
        nativeSelect.value = option.dataset.value || '';
        nativeSelect.dispatchEvent(new Event('change', { bubbles: true }));
        syncDropdownUI(id, items);
        container.classList.remove('open');
      };
    }
  }

  async function loadFormData() {
    try {
      const { data: clientes } = await supabase.from('clientes').select('id, nome').order('nome');
      const { data: tatuadores } = await supabase.from('tatuadores').select('id, nome').order('nome');

      clientsList = clientes || [];
      artistsList = tatuadores || [];

      updateCustomDropdown('cliente', clientsList, 'Selecione um cliente');
      updateCustomDropdown('tatuador', artistsList, 'Selecione um tatuador');
      updateCustomDropdown('status', statusList, 'Pendente');
    } catch (err) {
      console.error('Erro ao carregar dados do formulário:', err);
    }
  }

  async function sendWhatsAppConfirmation(appointmentId: string, estudioId: string) {
    try {
      const { data: appt, error: apptError } = await supabase
        .from('agendamentos')
        .select('*, cliente:clientes(nome, whatsapp), tatuador:tatuadores(nome), estudio:estudios(nome)')
        .eq('id', appointmentId)
        .single();
      
      if (apptError || !appt) return;

      const { data: template } = await supabase
        .from('template_mensagens')
        .select('conteudo')
        .eq('estudio_id', estudioId)
        .eq('tipo', 'agendamento_criado')
        .single();
      
      if (!template) return;

      const { data: conexao } = await supabase
        .from('conexao_whatsapp')
        .select('instance_name, status')
        .eq('estudio_id', estudioId)
        .single();
      
      if (!conexao || conexao.status !== 'connected') return;

      const dt = new Date(appt.data_hora);
      const dataStr = dt.toLocaleDateString('pt-BR');
      const horaStr = dt.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
      const valorStr = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(appt.valor_total);
      
      let mensagem = template.conteudo
        .replace(/{cliente_nome}/g, appt.cliente?.nome || '')
        .replace(/{tatuador_nome}/g, appt.tatuador?.nome || '')
        .replace(/{data}/g, dataStr)
        .replace(/{hora}/g, horaStr)
        .replace(/{valor}/g, valorStr)
        .replace(/{estudio_nome}/g, appt.estudio?.nome || '');

      let telefone = (appt.cliente?.whatsapp || '').replace(/\D/g, '');
      if (telefone && !telefone.startsWith('55') && telefone.length >= 10) telefone = '55' + telefone;

      if (!telefone) return;

      const payload = {
        agendamento_id: appointmentId,
        estudio_id: estudioId,
        tipo_mensagem: 'agendamento_criado',
        instancia: conexao.instance_name,
        cliente_nome: appt.cliente?.nome || '',
        telefone: telefone,
        tatuador_nome: appt.tatuador?.nome || '',
        data: dataStr,
        hora: horaStr,
        estudio_nome: appt.estudio?.nome || '',
        mensagem: mensagem
      };

      fetch(WEBHOOK_N8N, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        keepalive: true
      });

    } catch (err) {
      console.error('[n8n] Erro no envio do WhatsApp:', err);
    }
  }

  function closeAllDropdowns() {
    document.querySelectorAll('.custom-select-container').forEach(c => c.classList.remove('open'));
  }

  document.addEventListener('click', () => closeAllDropdowns());

  function closeModal() {
    modal?.classList.add('hidden');
    form?.reset();
    (document.getElementById('editing-id') as HTMLInputElement).value = '';
    const saveBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (saveBtn) {
      saveBtn.disabled = false;
      saveBtn.innerText = 'Salvar Agendamento';
    }
  }

  if (closeBtn) closeBtn.onclick = closeModal;
  if (cancelBtn) cancelBtn.onclick = closeModal;

  if (btnNewClient) {
    btnNewClient.onclick = (e) => {
      e.preventDefault();
      window.dispatchEvent(new CustomEvent('open-new-client-modal'));
    };
  }

  window.addEventListener('client-created', async (e: any) => {
    const newClient = e.detail;
    if (newClient) {
      const { data: clientes } = await supabase.from('clientes').select('id, nome').order('nome');
      if (clientes) updateCustomDropdown('cliente', clientes, 'Selecione um cliente');
    }
  });

  const fileInput = document.getElementById('referencias-input') as HTMLInputElement;
  const previewContainer = document.getElementById('preview-container');
  let selectedFiles: File[] = [];
  let existingReferences: any[] = [];

  document.getElementById('upload-dropzone')?.addEventListener('click', () => fileInput.click());

  fileInput.onchange = () => {
    if (fileInput.files) {
      const files = Array.from(fileInput.files).filter(f => f.size <= 5 * 1024 * 1024);
      selectedFiles = [...selectedFiles, ...files];
      renderPreviews();
    }
  };

  function renderPreviews() {
    if (!previewContainer) return;
    previewContainer.innerHTML = '';
    const deleteIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>`;

    existingReferences.forEach((ref) => {
      const { data } = supabase.storage.from('referencias').getPublicUrl(ref.storage_path);
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.innerHTML = `<img src="${data.publicUrl}" /> <button type="button" class="remove-preview" data-id="${ref.id}" data-path="${ref.storage_path}">${deleteIcon}</button>`;
      div.onclick = (e) => {
        if ((e.target as HTMLElement).closest('.remove-preview')) {
          if (confirm('Excluir referência?')) {
            supabase.from('agendamento_referencias').delete().eq('id', ref.id).then(() => {
              existingReferences = existingReferences.filter(r => r.id !== ref.id);
              renderPreviews();
            });
          }
        } else {
          openZoom(data.publicUrl);
        }
      };
      previewContainer.appendChild(div);
    });

    selectedFiles.forEach((file, index) => {
      const url = URL.createObjectURL(file);
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.innerHTML = `<img src="${url}" /> <button type="button" class="remove-preview" data-index="${index}">${deleteIcon}</button>`;
      div.onclick = (e) => {
        if ((e.target as HTMLElement).closest('.remove-preview')) {
          selectedFiles.splice(index, 1);
          renderPreviews();
        } else {
          openZoom(url);
        }
      };
      previewContainer.appendChild(div);
    });
  }

  function openZoom(url: string) {
    const zImg = document.getElementById('zoom-img') as HTMLImageElement;
    if (zImg) zImg.src = url;
    document.getElementById('modal-zoom')?.classList.remove('hidden');
  }

  const closeZoomBtn = document.getElementById('close-zoom');
  if (closeZoomBtn) {
    closeZoomBtn.onclick = () => document.getElementById('modal-zoom')?.classList.add('hidden');
  }

  const inputHora = document.getElementById('hora') as HTMLInputElement;
  const inputDuracao = document.getElementById('duracao') as HTMLInputElement;
  const inputHoraFim = document.getElementById('hora_fim') as HTMLInputElement;

  function updateEndTime() {
    if (!inputHora || !inputDuracao || !inputHoraFim) return;
    if (!inputHora.value || !inputDuracao.value) return;
    const [h, m] = inputHora.value.split(':').map(Number);
    const end = new Date();
    end.setHours(h, m + parseInt(inputDuracao.value));
    inputHoraFim.value = `${String(end.getHours()).padStart(2, '0')}:${String(end.getMinutes()).padStart(2, '0')}`;
  }

  inputHora.oninput = updateEndTime;
  inputDuracao.oninput = updateEndTime;

  form.onsubmit = async (e) => {
    e.preventDefault();
    const saveBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    saveBtn.disabled = true;
    saveBtn.innerText = 'Salvando...';

    try {
      const { data: { user } } = await supabase.auth.getUser();
      const { data: prof } = await supabase.from('users').select('estudio_id').eq('id', user?.id).single();
      const editingId = (document.getElementById('editing-id') as HTMLInputElement).value;
      const formData = new FormData(form);

      const dataStr = formData.get('data') as string;
      const horaStr = formData.get('hora') as string;
      const duracaoMin = parseInt(formData.get('duracao_minutos') as string);
      
      const startDt = new Date(`${dataStr}T${horaStr}:00`);
      const endDt = new Date(startDt.getTime() + (duracaoMin * 60000));

      const apptData = {
        cliente_id: formData.get('cliente_id'),
        tatuador_id: formData.get('tatuador_id'),
        data_hora: startDt.toISOString(),
        duracao_minutos: duracaoMin,
        data_hora_fim: endDt.toISOString(),
        valor_total: parseFloat(formData.get('valor_total') as string || '0'),
        valor_sinal: parseFloat(formData.get('valor_sinal') as string || '0'),
        pago: formData.get('pago') === 'on',
        sinal_pago: formData.get('sinal_pago') === 'on',
        status: formData.get('status') || 'Pendente',
        estudio_id: prof.estudio_id
      };

      let id = editingId;
      if (editingId) {
        await supabase.from('agendamentos').update(apptData).eq('id', editingId);
      } else {
        const { data } = await supabase.from('agendamentos').insert([apptData]).select().single();
        id = data.id;
        await sendWhatsAppConfirmation(id, prof.estudio_id);
      }

      for (const file of selectedFiles) {
        const path = `${prof.estudio_id}/${id}/${crypto.randomUUID()}`;
        await supabase.storage.from('referencias').upload(path, file);
        await supabase.from('agendamento_referencias').insert({ agendamento_id: id, storage_path: path });
      }

      closeModal();
      window.dispatchEvent(new CustomEvent('appointment-saved'));
    } catch (err) {
      alert('Erro ao salvar');
    } finally {
      saveBtn.disabled = false;
      saveBtn.innerText = 'Salvar Agendamento';
    }
  };

  window.addEventListener('open-new-appointment-modal', async (e: any) => {
    const { appointment, date, time } = e.detail || {};
    const modal = document.getElementById('new-appointment-modal');
    const modalTitle = document.getElementById('modal-title');
    const form = document.getElementById('new-appointment-form') as HTMLFormElement;
    
    form.reset();
    existingReferences = [];
    selectedFiles = [];
    (document.getElementById('editing-id') as HTMLInputElement).value = '';
    
    await loadFormData();
    
    if (appointment) {
      if (modalTitle) modalTitle.textContent = 'Editar Agendamento';
      (document.getElementById('editing-id') as HTMLInputElement).value = appointment.id;
      
      (document.getElementById('cliente') as HTMLSelectElement).value = appointment.cliente_id;
      (document.getElementById('tatuador') as HTMLSelectElement).value = appointment.tatuador_id;
      (document.getElementById('status') as HTMLSelectElement).value = appointment.status;
      
      const dt = new Date(appointment.data_hora);
      (document.getElementById('data') as HTMLInputElement).value = dt.toISOString().split('T')[0];
      (document.getElementById('hora') as HTMLInputElement).value = dt.toTimeString().slice(0, 5);
      (document.getElementById('duracao') as HTMLInputElement).value = appointment.duracao_minutos;
      (document.getElementById('valor_total') as HTMLInputElement).value = appointment.valor_total;
      (document.getElementById('valor_sinal') as HTMLInputElement).value = appointment.valor_sinal;
      (document.getElementById('pago') as HTMLInputElement).checked = appointment.pago;
      (document.getElementById('sinal_pago') as HTMLInputElement).checked = appointment.sinal_pago;
      
      // Sincronizar UI dos dropdowns customizados APÓS setar os valores nativos
      syncDropdownUI('cliente', clientsList);
      syncDropdownUI('tatuador', artistsList);
      syncDropdownUI('status', statusList);

      const { data: refs } = await supabase.from('agendamento_referencias').select('*').eq('agendamento_id', appointment.id);
      if (refs) existingReferences = refs;
    } else {
      if (modalTitle) modalTitle.textContent = 'Novo Agendamento';
      if (date) (document.getElementById('data') as HTMLInputElement).value = date;
      if (time) (document.getElementById('hora') as HTMLInputElement).value = time;
      
      // Sincronizar UI para o estado inicial (Pendente e placeholders)
      syncDropdownUI('cliente', clientsList);
      syncDropdownUI('tatuador', artistsList);
      syncDropdownUI('status', statusList);
    }
    updateEndTime();
    renderPreviews();
    modal?.classList.remove('hidden');
  });
</script>

