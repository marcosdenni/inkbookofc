---
import '../styles/global.css';
import Header from '../components/landing/Header.astro';
import ProblemSection from '../components/landing/ProblemSection.astro';
import AiFeature from '../components/landing/AiFeature.jsx';
import SchedulingFeature from '../components/landing/SchedulingFeature.astro';
import Footer from '../components/landing/Footer.astro';
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content="InkBook — Transforme seu estúdio em uma máquina de agendamentos. Gestão premium para tatuadores." />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>InkBook | Gestão Premium para Tatuadores</title>
</head>
<body class="landing-body">
  <Header />

  <!-- ───── HERO ───── -->
  <section class="hero">
    <div class="hero__bg-grid"></div>
    <div class="hero__glow"></div>
  
    <div class="hero__inner">
      <!-- Texto Centralizado -->
      <div class="hero__copy">
        <div class="hero__badge reveal">
          <span class="badge-dot"></span>
          Gestão profissional para tatuadores
        </div>
  
        <h1 class="hero__h1 reveal delay-100">
          Transforme seu estúdio em uma
          <em class="hero__h1-em">máquina de agendamentos.</em>
        </h1>
  
        <p class="hero__sub reveal delay-200">
          A gestão completa que entende a arte da tatuagem. <span class="gold-text">Automatize seu WhatsApp</span>, confirme horários e organize sua agenda com elegância — tudo em um só lugar.
        </p>
  
        <div class="hero__actions reveal delay-300">
          <a href="/login" class="btn btn--primary">
            Começar agora profissionalmente
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#problemas" class="btn btn--ghost">Ver funcionalidades</a>
        </div>
  
        <div class="hero__stats reveal delay-300">
          <div class="stat">
            <span class="stat__num">100%</span>
            <span class="stat__label"><span class="gold-text">WhatsApp</span> automatizado</span>
          </div>
          <div class="stat-div"></div>
          <div class="stat">
            <span class="stat__num">ZERO</span>
            <span class="stat__label"><span class="gold-text">No-shows</span> garantidos</span>
          </div>
          <div class="stat-div"></div>
          <div class="stat">
            <span class="stat__num">+24h</span>
            <span class="stat__label">Tempo Economizado</span>
          </div>
        </div>
      </div>
  
      <!-- Visual em Largura Total -->
      <div class="hero__visual reveal delay-400">
        <div class="hero__screen-wrap">
          <div class="hero__screen-frame">
            <div class="hero__screen-bar">
              <div class="sbar-dots">
                <span class="sbar-dot red"></span>
                <span class="sbar-dot yellow"></span>
                <span class="sbar-dot green"></span>
              </div>
              <div class="sbar-url">app.inkbook.com.br/agenda</div>
            </div>
            <img
              src="/imagens/Captura de Tela (851).png"
              alt="Agenda semanal InkBook"
              class="hero__screenshot"
              loading="eager"
            />
          </div>
          
          <!-- Floating Cards -->
          <div class="hero__float-card card-1">
            <div class="float-icon">📱</div>
            <div>
              <div class="float-title">WhatsApp Integrado</div>
              <div class="float-sub">Confirmação automática</div>
            </div>
          </div>
  
          <div class="hero__float-card card-2">
            <div class="float-icon">📅</div>
            <div>
              <div class="float-title">Agenda Inteligente</div>
              <div class="float-sub">Sincronização instantânea</div>
            </div>
          </div>
          
          <div class="hero__glow-behind"></div>
        </div>
      </div>
    </div>
  </section>

  <ProblemSection />
  <AiFeature client:visible />
  <SchedulingFeature />
  <Footer />

  <script>
    // Scroll Reveal — entra ao entrar na viewport
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('active');
          revealObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // Stagger automático para listas de items
    document.querySelectorAll('[data-stagger]').forEach(container => {
      const children = Array.from(container.children);
      children.forEach((child, i) => {
        child.classList.add('reveal');
        (child as HTMLElement).style.transitionDelay = `${i * 110}ms`;
        revealObserver.observe(child);
      });
    });
  </script>

  <style>
    .landing-body {
      background: #080808;
      color: #f5f5f5;
      font-family: var(--font-text);
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    /* ── Shared Utilities ── */
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 4rem;
    }
    @media (max-width: 1024px) {
      .container { padding: 0 2.5rem; }
    }
    @media (max-width: 768px) {
      .container { padding: 0 1.5rem; }
    }

    .section { padding: 10rem 0; }

    .reveal {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.active { opacity: 1; transform: translateY(0); }
    .delay-100 { transition-delay: 100ms; }
    .delay-200 { transition-delay: 200ms; }
    .delay-300 { transition-delay: 320ms; }

    .gold-text {
      background: linear-gradient(135deg, #C9A24D 0%, #E8CC7A 50%, #C9A24D 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 1rem 2.25rem;
      border-radius: 10px;
      font-weight: 700;
      font-size: 1.05rem;
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      white-space: nowrap;
    }
    .btn--primary {
      background: #C9A24D;
      color: #000;
      box-shadow: 0 8px 24px rgba(201,162,77,0.3);
    }
    .btn--primary:hover {
      background: #E8CC7A;
      transform: translateY(-3px);
      box-shadow: 0 16px 36px rgba(201,162,77,0.4);
    }
    .btn--ghost {
      background: transparent;
      color: rgba(255,255,255,0.55);
      border: 1.5px solid rgba(255,255,255,0.12);
    }
    .btn--ghost:hover {
      color: #fff;
      border-color: rgba(255,255,255,0.3);
      background: rgba(255,255,255,0.04);
    }

    /* ──────────────────── HERO ──────────────────── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      padding-top: 120px;
      padding-bottom: 8rem;
    }

    /* Subtle grid background */
    .hero__bg-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black, transparent);
    }

    /* Glow top-center */
    .hero__glow {
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 600px;
      background: radial-gradient(ellipse, rgba(201,162,77,0.1) 0%, transparent 65%);
      pointer-events: none;
    }

    .hero__inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 4rem;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 4rem;
    }
    @media (max-width: 1024px) {
      .hero__inner { padding: 0 2.5rem; }
    }
    @media (max-width: 768px) {
      .hero__inner { padding: 0 1.5rem; }
    }
    @media (max-width: 768px) {
      .hero__inner { padding: 0 1.5rem; }
    }

    /* Badge */
    .hero__badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(201,162,77,0.08);
      border: 1px solid rgba(201,162,77,0.2);
      border-radius: 100px;
      padding: 0.45rem 1.1rem;
      font-size: 0.88rem;
      font-weight: 600;
      color: #C9A24D;
      letter-spacing: 0.3px;
      margin-bottom: 2rem;
    }
    .badge-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #C9A24D;
      box-shadow: 0 0 8px rgba(201,162,77,0.8);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* H1 */
    .hero__h1 {
      font-family: var(--font-title);
      font-size: clamp(3.8rem, 5.5vw, 6.5rem);
      line-height: 0.92;
      letter-spacing: -0.5px;
      color: #fff;
      margin-bottom: 2rem;
    }
    .hero__h1-em {
      font-style: normal;
      background: linear-gradient(135deg, #C9A24D 0%, #E8CC7A 50%, #B8902A 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Sub */
    .hero__sub {
      font-size: clamp(1.1rem, 1.5vw, 1.25rem);
      line-height: 1.65;
      color: rgba(255,255,255,0.5);
      margin-bottom: 3rem;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Actions */
    .hero__actions {
      display: flex;
      gap: 1.2rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 4rem;
    }

    /* Stats */
    .hero__stats {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(1.5rem, 4vw, 3rem);
      width: 100%;
    }
    .stat__num {
      display: block;
      font-family: var(--font-title);
      font-size: 2.2rem;
      color: #C9A24D;
      line-height: 1;
    }
    .stat__label {
      display: block;
      font-size: 0.82rem;
      color: rgba(255,255,255,0.35);
      margin-top: 0.3rem;
      font-weight: 500;
    }
    .stat-div {
      width: 1px;
      height: 36px;
      background: rgba(255,255,255,0.08);
    }

    /* ── Hero Visual ── */
    .hero__visual { 
      position: relative; 
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero__screen-wrap {
      position: relative;
      filter: drop-shadow(0 60px 80px rgba(0,0,0,0.8));
    }

    .hero__screen-frame {
      background: #0a0a0a;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.08);
      overflow: hidden;
      transform: perspective(1200px) rotateX(5deg);
      transition: all 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .hero__screen-frame:hover {
      transform: perspective(1200px) rotateX(0deg) translateY(-10px);
      border-color: rgba(201,162,77,0.4);
      box-shadow: 0 60px 100px rgba(0,0,0,0.8), 0 0 40px rgba(201,162,77,0.1);
    }

    .hero__screen-bar {
      background: rgba(255,255,255,0.02);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding: 12px 20px;
      display: flex;
      align-items: center;
      position: relative;
    }
    .sbar-dots {
      display: flex;
      gap: 8px;
    }
    .sbar-dot {
      width: 11px; height: 11px; border-radius: 50%;
    }
    .sbar-dot.red { background: #FF5F56; }
    .sbar-dot.yellow { background: #FFBD2E; }
    .sbar-dot.green { background: #27C93F; }
    .sbar-url {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-mono, monospace);
      font-size: 0.75rem;
      color: rgba(255,255,255,0.25);
      background: rgba(255,255,255,0.03);
      padding: 4px 16px;
      border-radius: 6px;
      border: 1px solid rgba(255,255,255,0.05);
    }

    .hero__screenshot {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
      object-position: top;
    }

    /* Floating Cards */
    .hero__float-card {
      position: absolute;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(201,162,77,0.2);
      border-radius: 16px;
      padding: 1.2rem;
      display: flex;
      align-items: center;
      gap: 1.2rem;
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
      z-index: 10;
    }
    .hero__float-card.card-1 {
      top: 15%;
      left: -5%;
      animation: float 6s ease-in-out infinite;
    }
    .hero__float-card.card-2 {
      bottom: 20%;
      right: -5%;
      animation: float 6s ease-in-out infinite reverse;
      animation-delay: 1s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0); }
      50% { transform: translateY(-15px) rotate(1deg); }
    }

    @media (max-width: 1200px) {
      .hero__float-card { display: none; }
    }

    .float-icon { 
      font-size: 1.8rem;
      background: rgba(201,162,77,0.1);
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
    }
    .float-title { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
    .float-sub { font-size: 0.85rem; color: rgba(255,255,255,0.4); }

    .hero__glow-behind {
      position: absolute;
      top: 30%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 100%;
      height: 100%;
      background: radial-gradient(circle, rgba(201,162,77,0.18) 0%, transparent 65%);
      z-index: -1;
      pointer-events: none;
    }
  </style>
</body>
</html>
