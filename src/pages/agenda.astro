  };
  document.getElementById('btn-view-day').onclick = () => {
    if(viewMode === 'day') return;
    viewMode = 'day';
    document.getElementById('btn-view-day').classList.add('active');
    document.getElementById('btn-view-week').classList.remove('active');
    loadAgenda();
  };

  document.getElementById('btn-new-slot').onclick = () => window.dispatchEvent(new CustomEvent('open-new-appointment-modal'));
  
  const closeDetails = () => document.getElementById('modal-details').classList.add('hidden');
  document.getElementById('close-details').onclick = closeDetails;

  // INIT
  if (viewMode === 'day') {
    document.getElementById('btn-view-day').classList.add('active');
    document.getElementById('btn-view-week').classList.remove('active');
  }
  loadAgenda();
  window.addEventListener('appointment-saved', loadAgenda);

  // REALTIME SUBSCRIPTION
  const channel = supabase
    .channel('agendamentos-changes')
    .on('postgres_changes', { 
      event: '*', 
      schema: 'public', 
      table: 'agendamentos' 
    }, (payload) => {
      console.log('Mudança detectada nos agendamentos:', payload.eventType);
      loadAgenda();
    })
    .subscribe();
</script>

