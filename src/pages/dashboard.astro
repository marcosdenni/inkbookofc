---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import DashboardStats from '../components/DashboardStats.astro';
import AppointmentList from '../components/AppointmentList.astro';
import DashboardCharts from '../components/DashboardCharts.astro';
import NewAppointmentModal from '../components/NewAppointmentModal.astro';
import NewClientModal from '../components/NewClientModal.astro';
import { supabase } from '../lib/supabase';

// Saudação Baseada na Hora
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Bom dia' : hour < 18 ? 'Boa tarde' : 'Boa noite';

// Placeholders para renderização inicial (serão preenchidos pelo Script no Cliente)
const emptyStats = { total: 0, confirmados: 0, pendentes: 0, cancelados: 0 };
---

<DashboardLayout title="Inteligência do Estúdio">
  <div class="dashboard-wrapper">
    <!-- 1) HEADER -->
    <header class="dashboard-header">
      <div class="header-titles">
        <h1 class="greeting-text">{greeting}, <span class="accent-gold" id="studio-name-display">Carregando...</span></h1>
        <p class="current-date-muted" id="dashboard-date-display"></p>
      </div>
      
      <div class="header-actions">
        <div class="global-period-selector">
          <button class="period-btn active" data-period="hoje">Hoje</button>
          <button class="period-btn" data-period="semana">Semana</button>
          <button class="period-btn" data-period="mes">Mês</button>
        </div>
        <button id="add-appointment-btn" class="btn-premium-action">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span>Novo Agendamento</span>
        </button>
      </div>
    </header>

    <!-- 2) CARDS — OPERAÇÃO -->
    <section class="dashboard-section">
      <div class="section-header-compact">
        <h2 class="section-label">Operação</h2>
      </div>
      <div class="stats-horizontal-grid" id="stats-grid-root">
        <DashboardStats id="stat-total" label="Agendamentos" value={0} trend={{ value: 0, isUp: true }} />
        <DashboardStats id="stat-confirmados" label="Confirmados" value={0} variant="success" />
        <DashboardStats id="stat-pendentes" label="Pendentes" value={0} variant="warning" />
        <DashboardStats id="stat-cancelados" label="Cancelados" value={0} variant="error" />
        <DashboardStats id="stat-faltas" label="Faltas" value={0} variant="default" />
      </div>
    </section>

    <!-- 3) CARDS — FINANCEIRO -->
    <section class="dashboard-section">
      <div class="section-header-compact">
        <h2 class="section-label">Financeiro</h2>
      </div>
      <div class="stats-horizontal-grid financial-grid" id="finance-grid-root">
        <DashboardStats 
          id="stat-receita-prevista" 
          label="Receita Prevista" 
          value="R$ 0" 
          variant="gold" 
          weight={1} 
          description="Total estimado no período"
          showProgress={true}
        />
        <DashboardStats 
          id="stat-receita-recebida" 
          label="Receita Recebida" 
          value="R$ 0" 
          variant="success" 
          weight={2}
        />
        <DashboardStats 
          id="stat-valor-pendente" 
          label="Valor Pendente" 
          value="R$ 0" 
          variant="error" 
          weight={2}
          description="Aguardando pagamento"
        />
        <DashboardStats 
          id="stat-sinais-recebidos" 
          label="Sinais Recebidos" 
          value="R$ 0" 
          variant="gold" 
          weight={3}
        />
        <DashboardStats 
          id="stat-ticket-medio" 
          label="Ticket Médio" 
          value="R$ 0" 
          variant="default" 
          weight={3}
          description="Média por agendamento"
        />
      </div>
    </section>



    <!-- GRID LADO A LADO -->
    <div class="composite-grid">
      <!-- 1) PRÓXIMOS AGENDAMENTOS -->
      <section class="large-card-container">
        <div class="large-card">
          <div class="large-card-header">
            <h2 class="card-title">Próximos Agendamentos</h2>
            <a href="/agenda" class="link-view-all">Ver todos</a>
          </div>
          <div id="appointments-root" class="large-card-body scroll-vertical">
            <div class="empty-state-card"><p>Carregando agendamentos...</p></div>
          </div>
        </div>
      </section>

      <!-- 2) WHATSAPP / AUTOMAÇÃO -->
      <section class="large-card-container">
        <div class="large-card">
          <div class="large-card-header">
            <h2 class="card-title">Automação</h2>
            <a href="/mensagens" class="link-view-all">Configurar</a>
          </div>
          <div class="large-card-body automation-body">
            <div id="whatsapp-status-card" class="wa-status-card">
              <div class="wa-card-left">
                <div class="wa-icon-wrapper">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.656 1.438 5.166L2 22l4.934-1.42A9.956 9.956 0 0 0 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.96 7.96 0 0 1-4.164-1.17l-.297-.177-3.073.885.843-3.144-.194-.311A8 8 0 1 1 12 20z"/>
                  </svg>
                </div>
                <div class="wa-card-info">
                  <span class="wa-card-title">WhatsApp</span>
                  <span class="wa-card-subtitle" id="wa-dash-status-text">Verificando...</span>
                </div>
              </div>
              <div class="wa-card-right">
                <div class="wa-indicator" id="wa-dash-dot"></div>
              </div>
            </div>
            
            <div id="wa-dash-details" class="wa-details-box hidden">
                <div class="wa-detail-row">
                    <span class="wa-detail-label">Status:</span>
                    <span class="wa-detail-value" id="wa-dash-status-badge">Conectado</span>
                </div>
                <div class="wa-detail-row">
                    <span class="wa-detail-label">Desde:</span>
                    <span class="wa-detail-value" id="wa-dash-date"></span>
                </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div id="pending-alert-container"></div>
  </div>

  <NewAppointmentModal clientes={[]} tatuadores={[]} />
  <NewClientModal />

  <style>
    /* ═══ WHATSAPP STATUS CARD ═══ */
    .wa-status-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: all 0.3s ease;
    }

    .wa-status-card.connected {
      border-color: rgba(37, 211, 102, 0.2);
      background: linear-gradient(135deg, #141414 0%, rgba(37, 211, 102, 0.03) 100%);
    }

    .wa-card-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .wa-icon-wrapper {
      width: 42px;
      height: 42px;
      background: rgba(37, 211, 102, 0.1);
      border: 1px solid rgba(37, 211, 102, 0.15);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #25D366;
      flex-shrink: 0;
    }

    .wa-card-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      color: #fff;
      letter-spacing: 1px;
      display: block;
    }

    .wa-card-subtitle {
      font-size: 0.82rem;
      color: #666;
      font-weight: 600;
      display: block;
      margin-top: 2px;
    }

    .wa-card-subtitle.online { color: #25D366; }

    .wa-card-right {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .wa-connection-details {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
    }

    .wa-detail-item {
      font-size: 0.83rem;
      color: #ccc;
      font-weight: 600;
    }

    .wa-detail-item.muted {
      color: #555;
      font-weight: 500;
      font-size: 0.75rem;
    }

    .wa-indicator {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #ef4444;
      box-shadow: 0 0 8px #ef4444;
      flex-shrink: 0;
      transition: all 0.4s ease;
    }

    .wa-indicator.online {
      background: #25D366;
      box-shadow: 0 0 12px rgba(37, 211, 102, 0.6);
    }

    .dashboard-wrapper {
      display: flex;
      flex-direction: column;
      gap: 3rem;
      padding: 0 1rem;
      animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      max-width: 1600px;
      margin: 0 auto;
      width: 100%;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* 1) HEADER STYLES */
    .dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .greeting-text {
      font-size: 3rem;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 0.5rem;
      letter-spacing: -1.5px;
    }

    .accent-gold { color: var(--primary); }

    .current-date-muted {
      color: var(--text-muted);
      opacity: 0.6;
      font-size: 1.1rem;
      font-weight: 500;
      text-transform: capitalize;
    }

    .btn-premium-action {
      background: linear-gradient(135deg, var(--primary) 0%, #e5c07b 100%);
      color: #000;
      border: none;
      padding: 1rem 2rem;
      border-radius: 14px;
      font-weight: 800;
      font-size: 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      cursor: pointer;
      transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
      box-shadow: 0 10px 30px -10px rgba(201, 162, 77, 0.5);
    }

    .btn-premium-action:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 20px 40px -15px rgba(201, 162, 77, 0.6);
      filter: brightness(1.1);
    }

    /* 2) STATS GRID STYLES */
    .stats-horizontal-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1.5rem;
    }

    .financial-grid {
      grid-template-columns: repeat(6, 1fr); /* Grade maior para suportar os spans de peso */
      gap: 1.5rem;
      margin-top: 1rem;
    }

    /* Respiro extra entre seções */
    section.dashboard-section + section.dashboard-section {
      margin-top: 1.5rem;
    }

    /* 3 & 4) LARGE CARDS & COMPOSITE GRID */
    .composite-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
    }

    .automation-body {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .wa-details-box {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 14px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .wa-detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        padding-bottom: 0.75rem;
    }

    .wa-detail-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .wa-detail-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .wa-detail-value {
        font-size: 0.9rem;
        color: var(--text);
        font-weight: 600;
    }

    #wa-dash-status-badge {
        color: #25D366;
        background: rgba(37, 211, 102, 0.1);
        padding: 0.25rem 0.75rem;
        border-radius: 6px;
        font-size: 0.7rem;
        text-transform: uppercase;
    }

    .large-card {
      background-color: #2A2A2A;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      flex-direction: column;
      height: 100%;
      min-height: 500px;
      box-shadow: 0 15px 45px rgba(0, 0, 0, 0.3);
      overflow: hidden;
    }

    .large-card-header {
      padding: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .card-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
      text-transform: none;
      letter-spacing: 0;
    }

    .large-card-body {
      padding: 2rem;
      flex: 1;
    }

    .scroll-vertical {
      overflow-y: auto;
      max-height: 500px;
    }

    .link-view-all {
       color: var(--primary);
       font-weight: 700;
       text-decoration: none;
       font-size: 0.9rem;
       padding: 0.5rem 1rem;
       border-radius: 8px;
       transition: background 0.2s;
    }

    .link-view-all:hover {
       background: rgba(201, 162, 77, 0.1);
    }

    /* Period Selectors */
    .period-button-group {
      background: rgba(255, 255, 255, 0.03);
      padding: 0.4rem;
      border-radius: 12px;
      display: flex;
      gap: 0.25rem;
    }

    .period-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .period-btn.active {
      background: var(--primary);
      color: #000;
    }

    /* Chart Layout */
    .chart-layout {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .chart-wrapper {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 0;
    }

    .chart-summary-footer {
      padding-top: 2rem;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      margin-top: 1rem;
    }

    .summary-metric {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .summary-label {
      color: var(--text-muted);
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* Hover effects para o Gráfico Injetado */
    :global(.bar-wrapper:hover .bar) {
      opacity: 1 !important;
      filter: brightness(1.2);
      box-shadow: 0 0 15px var(--primary);
    }
    :global(.bar-wrapper:hover .bar-tooltip) {
      opacity: 1 !important;
    }

    .summary-value {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--primary);
      font-family: var(--font-text);
    }

    /* Scrollbar Style */
    .scroll-vertical::-webkit-scrollbar {
      width: 6px;
    }

    .scroll-vertical::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 10px;
    }

    /* NOVOS ESTILOS DASHBOARD EXECUTIVO */
    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .global-period-selector {
        background: rgba(255, 255, 255, 0.03);
        padding: 0.4rem;
        border-radius: 14px;
        display: flex;
        gap: 0.25rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .section-header-compact {
        margin-bottom: 1.25rem;
        padding-left: 0.5rem;
    }

    .section-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-muted);
        font-weight: 700;
        opacity: 0.6;
    }

    .financial-grid .stat-card {
        background: linear-gradient(135deg, #2a2a2a 0%, #252525 100%);
    }

    .performance-badges {
        display: flex;
        gap: 2rem;
    }

    .perf-badge {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .perf-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: 700;
        letter-spacing: 1px;
    }

    .perf-value {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text);
    }

    .card-subtitle {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-top: 0.25rem;
    }

    .operational-alerts-mini {
        margin-top: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .mini-alert {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .mini-alert.warning { color: var(--status-pending); background: rgba(201, 162, 77, 0.05); border-color: rgba(201, 162, 77, 0.1); }
    .mini-alert.error { color: var(--status-cancelled); background: rgba(192, 57, 43, 0.05); border-color: rgba(192, 57, 43, 0.1); }
    .mini-alert.info { color: var(--primary); background: rgba(201, 162, 77, 0.05); border-color: rgba(201, 162, 77, 0.1); }

    /* Estilos para a lista injetada com financeiro */
    :global(.col-finance) {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        padding: 0 1rem;
    }

    :global(.value-main) {
        font-weight: 700;
        color: var(--text);
        font-size: 0.95rem;
    }

    :global(.pay-indicator) {
        font-size: 0.65rem;
        text-transform: uppercase;
        font-weight: 800;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        margin-top: 0.25rem;
    }

    :global(.pay-indicator.paid) { background: rgba(39, 174, 96, 0.1); color: var(--status-confirmed); }
    :global(.pay-indicator.unpaid) { background: rgba(192, 57, 43, 0.1); color: var(--status-cancelled); }
    :global(.pay-indicator.partial) { background: rgba(201, 162, 77, 0.1); color: var(--status-pending); }

    /* ALERT STYLES */
    .alert-box {
      background: rgba(251, 191, 36, 0.05);
      border: 1px solid rgba(251, 191, 36, 0.2);
      color: #fbbf24;
      padding: 1.25rem 1.5rem;
      border-radius: 16px;
      display: flex;
      align-items: center;
      gap: 1rem;
      font-weight: 600;
    }

    /* PREMIUM LIST ITEMS */
    .premium-list-container {
      display: flex;
      flex-direction: column;
    }

    .appointment-item-premium {
      display: grid;
      grid-template-columns: 100px 1.5fr 1fr 140px;
      align-items: center;
      padding: 1.25rem 2rem;
      border-radius: 12px;
      margin-bottom: 0.25rem;
      transition: all 0.3s ease;
      border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    }

    .appointment-item-premium:last-child {
      border-bottom: none;
    }

    .appointment-item-premium:hover {
      background: rgba(255, 255, 255, 0.03);
      transform: translateX(5px);
    }

    .alternate-bg {
      background: rgba(255, 255, 255, 0.01);
    }

    .col-time {
      display: flex;
      align-items: center;
    }

    .time-text {
      font-family: var(--font-text);
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--primary);
    }

    .col-client {
      padding: 0 1rem;
    }

    .client-name-bold {
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--text);
    }

    .col-artist {
      padding: 0 1rem;
    }

    .artist-name-muted {
      font-size: 0.9rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .col-status {
      display: flex;
      justify-content: flex-end;
    }

    .status-badge-premium {
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      min-width: 110px;
      text-align: center;
    }

    .status-badge-premium.status-pendente {
      background: rgba(201, 162, 77, 0.1);
      color: var(--status-pending);
      border: 1px solid rgba(201, 162, 77, 0.2);
    }

    .status-badge-premium.status-confirmado {
      background: rgba(39, 174, 96, 0.1);
      color: var(--status-confirmed);
      border: 1px solid rgba(39, 174, 96, 0.2);
    }

    .status-badge-premium.status-cancelado {
      background: rgba(192, 57, 43, 0.1);
      color: var(--status-cancelled);
      border: 1px solid rgba(192, 57, 43, 0.2);
    }

    .status-badge-premium.status-falta {
      background: rgba(109, 40, 217, 0.1);
      color: var(--status-missed);
      border: 1px solid rgba(109, 40, 217, 0.2);
    }

    /* Adições para Grid da Tabela Re-Injetada via :global */
    :global(.appointment-table) {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    :global(.appointment-grid-item) {
      display: grid;
      grid-template-columns: 100px 1.5fr 1fr 120px;
      align-items: center;
