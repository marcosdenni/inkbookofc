---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Assinatura & Planos">
  <div class="plans-wrapper">
    <!-- HEADER -->
    <header class="plans-header">
      <h1 class="premium-title">PLANOS</h1>
      <p class="premium-subtitle">Escolha o plano ideal para o seu estúdio</p>
    </header>

    <!-- GRID DE PLANOS -->
    <div class="plans-grid">
      <!-- PLANO GRATUITO -->
      <div class="plan-card" id="card-Gratuito">
        <div class="current-label" id="label-Gratuito" style="display: none;">Plano atual</div>
        <div class="plan-content">
          <h2 class="plan-name">GRATUITO</h2>
          <div class="plan-price">
            <span class="currency">R$</span>
            <span class="amount">0</span>
          </div>
          <p class="plan-description">Para quem está começando</p>
          
          <ul class="features-list">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Até 30 agendamentos/mês</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>1 tatuador</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Agenda básica</span>
            </li>
            <li class="disabled">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              <span>Sem automações</span>
            </li>
          </ul>

          <button 
            id="btn-Gratuito"
            class="btn-plan outline" 
            onclick="selectPlan('Gratuito')"
          >
            Começar grátis
          </button>
        </div>
      </div>

      <!-- PLANO PRO (DESTAQUE) -->
      <div class="plan-card featured" id="card-Pro">
        <div class="popular-badge">Mais popular</div>
        <div class="current-label" id="label-Pro" style="display: none;">Plano atual</div>
        <div class="plan-content">
          <h2 class="plan-name">PRO</h2>
          <div class="plan-price">
            <span class="currency">R$</span>
            <span class="amount">59</span>
            <span class="period">/mês</span>
          </div>
          <p class="plan-description">Otimize seu fluxo de trabalho</p>
          
          <ul class="features-list">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Agendamentos ilimitados</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Tatuadores ilimitados</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Automação WhatsApp</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Confirmação + Lembrete</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>IA para mensagens</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Dashboard completo</span>
            </li>
          </ul>

          <button 
            id="btn-Pro"
            class="btn-plan solid" 
            onclick="selectPlan('Pro')"
          >
            Assinar agora
          </button>
        </div>
      </div>

    </div>

    <!-- FAQ SECTION -->
    <section class="faq-section">
      <h2 class="faq-title">Perguntas Frequentes</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>Posso cancelar quando quiser?</h3>
          <p>Sim, você pode cancelar sua assinatura Pro a qualquer momento sem taxas de cancelamento.</p>
        </div>
        <div class="faq-item">
          <h3>Preciso de cartão no plano gratuito?</h3>
          <p>Não. O plano gratuito é 100% grátis para sempre e não exige dados de pagamento para começar.</p>
        </div>
        <div class="faq-item">
          <h3>O WhatsApp já está incluso?</h3>
          <p>Sim, a integração e o motor de disparo de mensagens já estão inclusos no plano PRO.</p>
        </div>
      </div>
    </section>
  </div>

  <style>
    .plans-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem 5rem;
      animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .plans-header {
      text-align: center;
      margin-bottom: 5rem;
    }

    .premium-title {
      font-size: 5rem;
      font-family: var(--font-title);
      color: var(--primary);
      margin-bottom: 0.5rem;
      letter-spacing: -2px;
      line-height: 1;
    }

    .premium-subtitle {
      font-size: 1.25rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* GRID */
    .plans-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      align-items: stretch;
      margin-bottom: 8rem;
    }

    /* CARDS */
    .plan-card {
      background-color: #141414;
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 24px;
      padding: 3rem 2.5rem;
      position: relative;
      display: flex;
      flex-direction: column;
      transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
      overflow: hidden;
    }

    .plan-card:hover {
      transform: translateY(-10px) scale(1.02);
      border-color: rgba(201, 162, 77, 0.3);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(201, 162, 77, 0.05);
    }

    /* FEATURED CARD */
    .plan-card.featured {
      border: 2px solid var(--primary);
      background: linear-gradient(180deg, #181818 0%, #141414 100%);
      box-shadow: 0 0 30px rgba(201, 162, 77, 0.1);
      z-index: 10;
    }

    .plan-card.featured:hover {
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(201, 162, 77, 0.15);
    }

    .popular-badge {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
      background: var(--primary);
      color: #000;
      padding: 0.4rem 1rem;
      border-radius: 30px;
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .current-label {
      position: absolute;
      top: 1.5rem;
      left: 1.5rem;
      color: var(--success);
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .current-label::before {
        content: '';
        display: block;
        width: 6px;
        height: 6px;
        background: var(--success);
        border-radius: 50%;
        box-shadow: 0 0 8px var(--success);
    }

    .plan-name {
      font-family: var(--font-title);
      font-size: 2.2rem;
      margin-bottom: 1.5rem;
      color: #fff;
    }

    .plan-price {
      display: flex;
      align-items: baseline;
      gap: 0.2rem;
      margin-bottom: 0.5rem;
    }

    .currency {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text-muted);
    }

    .amount {
      font-size: 4rem;
      font-weight: 800;
      color: #fff;
      line-height: 1;
    }

    .period {
      color: var(--text-muted);
      font-size: 1.1rem;
      font-weight: 600;
    }

    .plan-description {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-bottom: 2.5rem;
    }

    /* FEATURES */
    .features-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-bottom: 3.5rem;
      flex: 1;
    }

    .features-list li {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1rem;
      color: #e0e0e0;
      font-weight: 500;
    }

    .features-list li svg {
      color: var(--primary);
      flex-shrink: 0;
    }

    .features-list li.disabled {
      color: #555;
      text-decoration: line-through;
    }

    .features-list li.disabled svg {
      color: #444;
    }

    /* BUTTONS */
    .btn-plan {
      width: 100%;
      padding: 1.25rem;
      border-radius: 16px;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.3s ease;
      font-family: var(--font-text);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .btn-plan.outline {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #fff;
    }

    .btn-plan.outline:hover:not(:disabled) {
      background: rgba(255, 255, 255, 0.05);
      border-color: #fff;
    }

    .btn-plan.solid {
      background: var(--primary);
      border: none;
      color: #000;
      box-shadow: 0 10px 20px rgba(201, 162, 77, 0.2);
    }

    .btn-plan.solid:hover:not(:disabled) {
      transform: scale(1.02);
      filter: brightness(1.1);
      box-shadow: 0 15px 30px rgba(201, 162, 77, 0.3);
    }

    .btn-plan:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      border-color: rgba(255, 255, 255, 0.05);
      background: rgba(255, 255, 255, 0.02);
      color: #666;
      box-shadow: none;
    }

    /* FAQ */
    .faq-section {
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 6rem;
    }

    .faq-title {
      font-size: 2.5rem;
      text-align: center;
      margin-bottom: 4rem;
      color: #fff;
    }

    .faq-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }

    .faq-item h3 {
      font-size: 1.1rem;
      color: var(--primary);
      margin-bottom: 1rem;
      text-transform: none;
      letter-spacing: 0;
    }

    .faq-item p {
      color: var(--text-muted);
      line-height: 1.6;
      font-size: 0.95rem;
    }

    /* RESPONSIVITY */
    @media (max-width: 1024px) {
      .faq-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .premium-title { font-size: 3.5rem; }
      .plans-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      .faq-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      .plan-card {
        padding: 2rem 1.5rem;
      }
    }
  </style>

  <script>
    import { supabase } from '../lib/supabase';

    // Tornar disponível globalmente para o onclick no HTML
    window.selectPlan = async (plan) => {
      if (plan === 'Gratuito') {
        window.showToast?.('Você já está no plano Gratuito!', 'info');
        return;
      }

      if (plan === 'Pro') {
        const btn = document.getElementById('btn-Pro');
        if (!btn) return;
        const originalText = btn.innerText;
        
        try {
          // 1) Feedback visual
          btn.disabled = true;
          btn.innerText = 'Gerando pagamento...';

          // 2) Obter dados do usuário/estúdio
          const { data: { user } } = await supabase.auth.getUser();
          if (!user) throw new Error('Usuário não autenticado');

          const { data: userData, error: userError } = await supabase
            .from('users')
            .select('estudio_id')
            .eq('id', user.id)
            .single();

          if (userError || !userData) throw new Error('Não foi possível localizar seu estúdio');

          const { data: studioData, error: studioError } = await supabase
            .from('estudios')
            .select('id, nome, email, cnpj')
            .eq('id', userData.estudio_id)
            .single();

          if (studioError || !studioData) throw new Error('Erro ao buscar dados do estúdio');

          // 3) Requisição Webhook
          const response = await fetch('https://workflows-mvp.marcosdev.xyz/webhook/checkout-assinatura', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Api-Key': 'inkbook_secret_2026'
            },
            body: JSON.stringify({
              estudio_id: studioData.id,
              nome: studioData.nome,
              email: studioData.email,
              cpf_cnpj: studioData.cnpj
            })
          });

          if (!response.ok) throw new Error('Falha ao gerar o link de pagamento. Tente novamente.');

          const result = await response.json();
          
          if (result.checkoutUrl) {
            window.open(result.checkoutUrl, '_blank');
            window.showToast?.('Link de pagamento gerado! Finalize sua assinatura na aba aberta.', 'success');
          } else {
            throw new Error('URL de checkout não retornada pelo servidor');
          }

        } catch (err) {
          console.error('Erro no checkout:', err);
          window.showToast?.(err.message || 'Erro ao processar sua solicitação', 'error');
        } finally {
          btn.disabled = false;
          btn.innerText = originalText;
        }
      }
    };

    async function fetchCurrentPlan() {
      try {
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) return;

        // 1) Pegar o estudio_id do usuário
        const { data: userData, error: userError } = await supabase
          .from('users')
          .select('estudio_id')
          .eq('id', user.id)
          .single();

        if (userError || !userData) return;

        // 2) Pegar o plano do estúdio
        const { data: studioData, error: studioError } = await supabase
          .from('estudios')
          .select('plano')
          .eq('id', userData.estudio_id)
          .single();

        if (studioError || !studioData) return;

        const currentPlan = studioData.plano; // 'Gratuito' ou 'Pro'
        updatePlanUI(currentPlan);
      } catch (err) {
        console.error('Erro ao carregar plano:', err);
      }
    }

    function updatePlanUI(plan) {
      const plans = ['Gratuito', 'Pro'];
      
      plans.forEach(p => {
        const card = document.getElementById(`card-${p}`);
        const label = document.getElementById(`label-${p}`);
        const btn = document.getElementById(`btn-${p}`);

        if (!card || !btn) return;

        if (p === plan) {
          card.classList.add('active');
          if (label) label.style.display = 'flex';
          btn.disabled = true;
          btn.innerText = 'Plano Ativo';
        } else {
          card.classList.remove('active');
          if (label) label.style.display = 'none';
          btn.disabled = false;
          btn.innerText = p === 'Gratuito' ? 'Começar grátis' : 'Assinar agora';
        }
      });
    }

    // Inicializar
    fetchCurrentPlan();
  </script>
</DashboardLayout>
