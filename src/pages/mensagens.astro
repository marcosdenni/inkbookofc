  <script>
    import { supabase } from '../lib/supabase';

    let activeTextarea = null;
    let activeCard = null;

    // ══════════════════════════════════════
    // WHATSAPP — CONSTANTES E ESTADO
    // ══════════════════════════════════════
    const N8N_BASE = 'https://webhooks-mvp.marcosdev.xyz/webhook';
    let pollingInterval = null;
    let pollingTimeout = null;
    let pollingStartTime = null;
    const QR_TIMEOUT_MS = 120000; // 2 minutos
    const POLLING_INTERVAL_MS = 3000; // 3 segundos

    // Cache do contexto do usuário (preenchido no init)
    let cachedEstudioId = null;
    let cachedInstanceName = null;

    // ═══ SETUP INICIAL ═══ 
    async function init() {
      await loadTemplates();
      await checkWhatsAppStatus();
      await loadReminderConfig();
      setupEventListeners();
    }

    // ═══ CARREGAR DADOS ═══
    async function loadTemplates() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;

      const { data: estudio } = await supabase
        .from('users')
        .select('estudio_id')
        .eq('id', user.id)
        .single();
      
      if (!estudio) return;

      const { data: templates } = await supabase
        .from('template_mensagens')
        .select('*')
        .eq('estudio_id', estudio.estudio_id);

      if (templates) {
        templates.forEach(t => {
          const card = document.querySelector(`.template-card[data-tipo="${t.tipo}"]`);
          if (card) {
            const textarea = card.querySelector('textarea');
            textarea.value = t.conteudo;
            updateCharCount(card, t.conteudo.length);
          }
        });
      }
    }

    async function checkWhatsAppStatus() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;

      const { data: estudio } = await supabase
        .from('users')
        .select('estudio_id')
        .eq('id', user.id)
        .single();

      if (!estudio) return;

      cachedEstudioId = estudio.estudio_id;

      const { data: conexao } = await supabase
        .from('conexao_whatsapp')
        .select('*')
        .eq('estudio_id', estudio.estudio_id)
        .single();

      // Sem registro → mostrar botão Conectar (estado padrão)
      if (!conexao) {
        updateWhatsAppUI('disconnected');
        return;
      }

      cachedInstanceName = conexao.instance_name || null;

      if (conexao.status === 'connected') {
        // Verificar se ainda está conectado na API
        try {
          const res = await fetch(`${N8N_BASE}/get-qr?instance=${conexao.instance_name}`);
          if (res.ok) {
            const data = await res.json();
            if (data.status === 'connected') {
              updateWhatsAppUI('connected', conexao.numero_conectado || data.number);
              return;
            }
          }
        } catch (e) {
          console.warn('Não foi possível verificar status da API, usando banco.');
        }
        // Usar banco como fallback
        updateWhatsAppUI('connected', conexao.numero_conectado);
      } else {
        // waiting ou disconnected — mostrar botão Reconectar
        updateWhatsAppUI('waiting_or_disconnected');
      }
    }

    async function loadReminderConfig() {
      if (!cachedEstudioId) return;

      const { data, error } = await supabase
        .from('estudios')
        .select('lembrete_antes_minutos')
        .eq('id', cachedEstudioId)
        .single();

      if (error) {
        console.error('Erro ao carregar configuração de lembrete:', error);
        return;
      }

      const select = document.getElementById('select-lembrete-tempo') as HTMLSelectElement;
      if (select && data) {
        select.value = (data.lembrete_antes_minutos || 1440).toString();
      }
    }

    async function saveReminderConfig(minutes) {
      if (!cachedEstudioId) return;

      try {
        const { error } = await supabase
          .from('estudios')
          .update({ lembrete_antes_minutos: parseInt(minutes) })
          .eq('id', cachedEstudioId);

        if (error) throw error;
        showToast('Configuração de lembrete salva! ✓', 'success');
      } catch (err) {
        console.error('Erro ao salvar configuração de lembrete:', err);
        showToast('Erro ao salvar configuração.', 'error');
      }
    }

    // ═══ EVENT LISTENERS ═══
    function setupEventListeners() {
      // Textareas e Contadores
      document.querySelectorAll('.template-card textarea').forEach(txt => {
        txt.addEventListener('focus', () => {
          activeTextarea = txt;
          activeCard = txt.closest('.template-card');
        });

        txt.addEventListener('input', (e) => {
          const card = (e.target as HTMLElement).closest('.template-card');
          updateCharCount(card, (e.target as HTMLTextAreaElement).value.length);
        });
      });

      // Lembrete
      document.getElementById('select-lembrete-tempo')?.addEventListener('change', (e) => {
        const val = (e.target as HTMLSelectElement).value;
        saveReminderConfig(val);
      });

      // Clique nas Variáveis
      document.querySelectorAll('.var-chip').forEach(chip => {
        chip.addEventListener('click', () => {
          if (!activeTextarea) {
            console.warn('Nenhum campo de texto selecionado.');
            return;
          }
          const varName = chip.getAttribute('data-var');
          insertAtCursor(activeTextarea, varName);
          updateCharCount(activeCard, activeTextarea.value.length);
        });
      });

      // Salvar Template
      document.querySelectorAll('.btn-save-template').forEach(btn => {
        btn.addEventListener('click', async () => {
          const card = (btn as HTMLElement).closest('.template-card');
          if (!card) return;

          const tipo = card.getAttribute('data-tipo');
          const textarea = card.querySelector('textarea');
          if (!textarea) return;
          const conteudo = textarea.value;
          
          const originalBtnText = btn.textContent;
          btn.textContent = 'Salvando...';
          (btn as HTMLButtonElement).disabled = true;

          try {
            const { data: { user } } = await supabase.auth.getUser();
            if (!user) throw new Error('Usuário não autenticado.');

            const { data: estudio, error: estudioError } = await supabase
              .from('users')
              .select('estudio_id')
              .eq('id', user.id)
              .single();
            
            if (estudioError || !estudio?.estudio_id) {
              throw new Error('Estúdio não encontrado para este usuário.');
            }
            
            const { error } = await supabase
              .from('template_mensagens')
              .upsert({ 
                estudio_id: estudio.estudio_id, 
                tipo, 
                conteudo,
                updated_at: new Date().toISOString()
              }, { onConflict: 'estudio_id,tipo' });

            if (error) throw error;
            
            showToast('Template salvo com sucesso!', 'success');
          } catch (err: any) {
            console.error('Erro ao salvar template:', err);
            showToast(`Erro ao salvar: ${err.message || 'Erro desconhecido'}`, 'error');
          } finally {
            btn.textContent = originalBtnText;
            (btn as HTMLButtonElement).disabled = false;
          }
        });
      });

      // Otimizar IA (Mock)
      document.querySelectorAll('.btn-ia-optimize').forEach(btn => {
        btn.addEventListener('click', () => {
          const card = btn.closest('.template-card');
          const original = card.querySelector('textarea').value;
          
          if (!original.trim()) {
            showToast('Escreva algo para a IA otimizar.', 'info');
            return;
          }

          openIAModal(original);
        });
      });

      // ══════════════════════════════════════
      // WHATSAPP — EVENT LISTENERS REAIS
      // ══════════════════════════════════════

      document.getElementById('btn-connect-wa')?.addEventListener('click', () => connectWhatsApp());

      // Botão reconectar (mesmo elemento, comportamento igual)
      document.getElementById('btn-reconnect-wa')?.addEventListener('click', () => connectWhatsApp());

      // Fechar modal QR — para polling imediatamente
      document.getElementById('btn-close-qr-modal')?.addEventListener('click', () => {
        stopQrPolling();
        document.getElementById('modal-qr')?.classList.add('hidden');
      });

      // Clicar fora do modal QR
      document.getElementById('modal-qr')?.addEventListener('click', (e) => {
        if (e.target === document.getElementById('modal-qr')) {
          stopQrPolling();
          document.getElementById('modal-qr')?.classList.add('hidden');
        }
      });

      // Gerar novo QR após expiração
      document.getElementById('btn-renew-qr')?.addEventListener('click', () => {
        setQrState('loading');
        startQrPolling();
      });

      document.getElementById('btn-disconnect-wa')?.addEventListener('click', () => {
        document.getElementById('modal-disconnect-confirm')?.classList.remove('hidden');
      });

      document.getElementById('btn-confirm-disconnect')?.addEventListener('click', async () => {
        const btn = document.getElementById('btn-confirm-disconnect') as HTMLButtonElement;
        
        btn.textContent = 'Desconectando...';
        btn.disabled = true;

        try {
          await disconnectWhatsApp();
        } catch (err) {
          console.error(err);
        } finally {
          btn.textContent = 'Sim, Desconectar';
          btn.disabled = false;
        }
      });

      document.querySelector('.modal-close-disconnect')?.addEventListener('click', () => {
        document.getElementById('modal-disconnect-confirm')?.classList.add('hidden');
      });

      // Modal IA Controls — apenas fechar modal-ia (EXCLUINDO btn-close-qr-modal)
      document.querySelectorAll('.modal-close-btn:not(#btn-close-qr-modal)').forEach(btn => {
        btn.addEventListener('click', () => {
          document.getElementById('modal-ia')?.classList.add('hidden');
        });
      });

      // Modal Controls
      // (Removido daqui pois foi integrado acima)

      document.getElementById('btn-use-suggestion')?.addEventListener('click', async () => {
        const btn = document.getElementById('btn-use-suggestion') as HTMLButtonElement;
        const btnText = btn.querySelector('.btn-text');
        const btnLoader = btn.querySelector('.btn-loader');
        const suggestion = document.getElementById('ia-suggested-text').textContent;
        
        if (activeTextarea) {
          // Mostrar loading
          btnText?.classList.add('hidden');
          btnLoader?.classList.remove('hidden');
          btn.disabled = true;

          // Simular processamento/aplicação
          setTimeout(async () => {
            activeTextarea.value = suggestion;
            updateCharCount(activeCard, suggestion.length);
            
            // Salvar registro de sugestão usada (silencioso)
            try {
              const { data: { user } } = await supabase.auth.getUser();
              const { data: estudio } = await supabase.from('users').select('estudio_id').eq('id', user.id).single();
              
              await supabase.from('sugestao_mensagem_ia').insert({
                estudio_id: estudio.estudio_id,
                mensagem_original: document.getElementById('ia-original-text').textContent,
                mensagem_sugerida: suggestion,
                usada: true
              });
            } catch (e) {}

            btnText?.classList.remove('hidden');
            btnLoader?.classList.add('hidden');
            btn.disabled = false;
            document.getElementById('modal-ia').classList.add('hidden');
          }, 600);
        }
      });
    }

    // ═══ AUXILIARES ═══
    function updateCharCount(card, length) {
      if (!card) return;
      const counter = card.querySelector('.char-count');
      if (counter) counter.textContent = `${length} / 500`;
    }

    function insertAtCursor(textarea, text) {
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const val = textarea.value;
      textarea.value = val.substring(0, start) + text + val.substring(end);
      textarea.selectionStart = textarea.selectionEnd = start + text.length;
      textarea.focus();
    }

    // ══════════════════════════════════════
    // WHATSAPP — FUNÇÕES PRINCIPAIS
    // ══════════════════════════════════════

    async function disconnectWhatsApp() {
      stopQrPolling();

      if (!cachedInstanceName) return;

      try {
        await fetch("https://webhooks-mvp.marcosdev.xyz/webhook/disconnect-whatsapp", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            instance: cachedInstanceName
          })
        });

        const { error } = await supabase
          .from("conexao_whatsapp")
          .update({
            status: "disconnected",
            numero_conectado: null,
            connected_at: null,
            updated_at: new Date().toISOString()
          })
          .eq("estudio_id", cachedEstudioId);

        if (error) throw error;

        updateWhatsAppUI("disconnected");
        document.getElementById("modal-disconnect-confirm")?.classList.add("hidden");
        showToast("WhatsApp desconectado com sucesso", "info");
      } catch (err) {
        console.error("Erro ao desconectar WhatsApp:", err);
        showToast("Erro ao desconectar WhatsApp", "error");
      }
    }

    async function connectWhatsApp() {
      setConnectBtnState('loading');
      try {
        if (!cachedEstudioId) {
          const { data: { user } } = await supabase.auth.getUser();
          if (!user) { setConnectBtnState('idle'); return; }
          const { data: estudio } = await supabase.from('users').select('estudio_id').eq('id', user.id).single();
          if (!estudio) { setConnectBtnState('idle'); return; }
          cachedEstudioId = estudio.estudio_id;
        }

        // Verificar se instância já existe no banco
        const { data: conexao } = await supabase
          .from('conexao_whatsapp')
          .select('instance_name, status')
          .eq('estudio_id', cachedEstudioId)
          .single();

        if (!conexao || !conexao.instance_name) {
          // Nunca existiu — criar instância via n8n
          const instanceName = `inkbook_${cachedEstudioId}`;
          console.log('[WA] Criando instância:', instanceName);

          const res = await fetch(`${N8N_BASE}/create-instance`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ instance: instanceName })
          });

          if (!res.ok) throw new Error(`Erro ao criar instância: ${res.status} ${res.statusText}`);

          // Salvar no banco
          const { error: upsertErr } = await supabase.from('conexao_whatsapp').upsert({
            estudio_id: cachedEstudioId,
            instance_name: instanceName,
            status: 'waiting',
            updated_at: new Date().toISOString()
          }, { onConflict: 'estudio_id' });

          if (upsertErr) throw upsertErr;

          cachedInstanceName = instanceName;
          console.log('[WA] Instância criada com sucesso:', instanceName);
        } else {
          // Instância já existe — NUNCA recriar
          cachedInstanceName = conexao.instance_name;
          console.log('[WA] Instância existente reutilizada:', cachedInstanceName);
        }

        setConnectBtnState('idle');
        // Abrir modal e iniciar polling
        openQrModal();
      } catch (err: any) {
        console.error('[WA] Erro em connectWhatsApp:', err);
        setConnectBtnState('error');
        // Restaurar botão após 3s
        setTimeout(() => setConnectBtnState('idle'), 3000);
      }
    }

    function openQrModal() {
      const modal = document.getElementById('modal-qr');
      modal?.classList.remove('hidden');
      setQrState('loading');
      startQrPolling();
    }

    function startQrPolling() {
      stopQrPolling(); // Limpar qualquer polling anterior

      pollingStartTime = Date.now();
      updateQrTimer();

      pollingInterval = setInterval(async () => {
        // Verificar timeout
        const elapsed = Date.now() - pollingStartTime;
        if (elapsed >= QR_TIMEOUT_MS) {
          stopQrPolling();
          setQrState('expired');
          return;
        }

        await pollQrCode();
      }, POLLING_INTERVAL_MS) as any;

      // Chamada imediata para não esperar 3s
      pollQrCode();
    }

    async function pollQrCode() {
      if (!cachedInstanceName) return;

      try {
        const res = await fetch(`${N8N_BASE}/get-qr?instance=${cachedInstanceName}`);
        if (!res.ok) {
          console.warn('[WA] get-qr retornou:', res.status);
          return;
        }

        const data = await res.json();
        // Log completo para facilitar debug
        console.log('[WA] Resposta polling (raw):', JSON.stringify(data));

        // ── Detectar QR Code em múltiplos formatos possíveis ──
        // Evolution API pode retornar: data.base64, data.qrcode.base64,
        // data.qr, data.code, ou um array no nível raiz
        let qrBase64 = '';
        const root = Array.isArray(data) ? data[0] : data;

        if (root?.base64)             qrBase64 = root.base64;
        else if (root?.qrcode?.base64) qrBase64 = root.qrcode.base64;
        else if (root?.qr)             qrBase64 = root.qr;
        else if (root?.code)           qrBase64 = root.code;

        // Remove prefixo caso já venha como data URL
        if (qrBase64.startsWith('data:')) {
          qrBase64 = qrBase64; // usar como está
        } else if (qrBase64) {
          qrBase64 = `data:image/png;base64,${qrBase64}`;
        }

        // ── Detectar se já está conectado ──
        const statusStr = (root?.status || root?.state || root?.instance?.state || '').toLowerCase();
        const isConnected = statusStr === 'connected' || statusStr === 'open' || statusStr === 'confirmed';

        if (isConnected) {
          // Conectado!
          stopQrPolling();
          document.getElementById('modal-qr')?.classList.add('hidden');

          let number = root?.number || root?.ownerJid || root?.owner || root?.instance?.owner || root?.instance?.ownerJid || root?.instance?.number || '';
          
          /* CÓDIGO ANTIGO (COMENTADO PARA BACKUP)
          // Se a resposta nativa não trouxer o número (apenas confirmou que a instância conectou),
          // buscamos rapidamente nos endpoints de evolução para não salvar vazio
          if (!number) {
            try {
              const profileRes = await fetch(`${N8N_BASE}/get-profile?instance=${cachedInstanceName}`);
              if (profileRes.ok) {
                const profileData = await profileRes.json();
                number = profileData?.id || profileData?.number || profileData?.ownerJid || '';
              }
            } catch (e) {
              console.warn('[WA] Erro ao buscar profile extra:', e);
            }
          }
          */

          // NOVO FLUXO: Se não vier número, bate no webhook dedicado /pegar-numero
          if (!number) {
            try {
              const numRes = await fetch(`${N8N_BASE}/pegar-numero?instance=${cachedInstanceName}`);
              if (numRes.ok) {
                const numData = await numRes.json();
                // O n8n pode devolver o número em vários formatos, garantimos a leitura do root ou de props comuns
                number = numData?.numero || numData?.number || numData?.id || numData?.ownerJid || (typeof numData === 'string' ? numData : '');
                
                // Trata caso o n8n devolva um array (comum no webhook do n8n)
                if (Array.isArray(numData) && numData.length > 0) {
                   const firstItem = numData[0];
                   number = firstItem?.numero || firstItem?.number || firstItem?.id || firstItem?.ownerJid || '';
                }
              }
            } catch (e) {
              console.warn('[WA] Erro ao buscar numero via /pegar-numero:', e);
            }
          }

          if (number && typeof number === 'string') {
            number = number.split('@')[0].replace(/\D/g, ''); // Garante apenas os dígitos
          }

          if (!number) {
             console.warn('[WA] Não foi possível extrair o número na resposta:', root);
          }

          if (cachedEstudioId) {
            await supabase.from('conexao_whatsapp').update({
              status: 'connected',
              numero_conectado: number || null, // Se ainda for string vazia, salva nulo
              connected_at: new Date().toISOString(),
              updated_at: new Date().toISOString()
            }).eq('estudio_id', cachedEstudioId);
          }

          updateWhatsAppUI('connected', number);
          showToast('WhatsApp conectado com sucesso! ✓', 'success');

        } else if (qrBase64) {
          // Exibir QR Code
          const qrImg = document.getElementById('qr-image') as HTMLImageElement;
          if (qrImg) qrImg.src = qrBase64;
          setQrState('qr');

          // Atualizar last_qr_at no banco
          if (cachedEstudioId) {
            await supabase.from('conexao_whatsapp').update({
              last_qr_at: new Date().toISOString()
            }).eq('estudio_id', cachedEstudioId);
          }
        } else {
          console.log('[WA] Resposta sem QR nem status de conexão. Aguardando próximo ciclo.');
        }
      } catch (err) {
        console.warn('[WA] Erro no polling:', err);
      }
    }

    function stopQrPolling() {
      if (pollingInterval) {
        clearInterval(pollingInterval);
        pollingInterval = null;
      }
      if (pollingTimeout) {
        clearTimeout(pollingTimeout);
        pollingTimeout = null;
      }
      console.log('[WA] Polling parado.');
    }

    function setQrState(state: 'loading' | 'qr' | 'expired') {
      document.getElementById('qr-loading')?.classList.toggle('hidden', state !== 'loading');
      document.getElementById('qr-display')?.classList.toggle('hidden', state !== 'qr');
      document.getElementById('qr-expired')?.classList.toggle('hidden', state !== 'expired');
    }

    function updateQrTimer() {
      const timerEl = document.getElementById('qr-timer');
      if (!timerEl || !pollingStartTime) return;

      const update = () => {
        if (!pollingStartTime) return;
        const elapsed = Date.now() - pollingStartTime;
        const remaining = Math.max(0, Math.ceil((QR_TIMEOUT_MS - elapsed) / 1000));
        if (timerEl) timerEl.textContent = remaining > 0 ? `QR expira em ${remaining}s` : '';
        if (remaining > 0 && pollingInterval !== null) requestAnimationFrame(update);
      };
      requestAnimationFrame(update);
    }

    function setConnectBtnState(state: 'loading' | 'idle' | 'error') {
      const connectBtn = document.getElementById('btn-connect-wa') as HTMLButtonElement;
      const reconnectBtn = document.getElementById('btn-reconnect-wa') as HTMLButtonElement;

      if (state === 'loading') {
        if (connectBtn) { connectBtn.textContent = 'Conectando...'; connectBtn.disabled = true; }
        if (reconnectBtn) { reconnectBtn.textContent = 'Conectando...'; reconnectBtn.disabled = true; }
      } else if (state === 'error') {
        if (connectBtn) { connectBtn.textContent = 'Erro — Tentar novamente'; connectBtn.disabled = false; }
        if (reconnectBtn) { reconnectBtn.textContent = 'Erro — Tentar novamente'; reconnectBtn.disabled = false; }
      } else {
        if (connectBtn) { connectBtn.textContent = 'Conectar WhatsApp'; connectBtn.disabled = false; }
        if (reconnectBtn) { reconnectBtn.textContent = 'Reconectar WhatsApp'; reconnectBtn.disabled = false; }
      }
    }

    function updateWhatsAppUI(state: 'connected' | 'disconnected' | 'waiting_or_disconnected', number = '') {
      const statusInd = document.getElementById('whatsapp-status');
      const statusText = statusInd?.querySelector('.status-text');
      const disconnectedArea = document.getElementById('whatsapp-disconnected');
      const connectedArea = document.getElementById('whatsapp-connected');
      const numEl = document.getElementById('connected-number');
      const connectBtn = document.getElementById('btn-connect-wa');
      const reconnectBtn = document.getElementById('btn-reconnect-wa');

      if (state === 'connected') {
        statusInd?.classList.add('connected');
        if (statusText) statusText.textContent = 'Conectado';
        disconnectedArea?.classList.add('hidden');
        connectedArea?.classList.remove('hidden');
        const formatted = formatPhoneNumber(number);
        if (numEl) {
           numEl.textContent = formatted || number || '(Número desconhecido)';
           if(!formatted && !number) {
              numEl.style.opacity = '0.5';
           } else {
              numEl.style.opacity = '1';
           }
        }
      } else if (state === 'waiting_or_disconnected') {
        // Instância existe mas não conectada — mostrar Reconectar
        statusInd?.classList.remove('connected');
        if (statusText) statusText.textContent = 'Desconectado';
        connectedArea?.classList.add('hidden');
        disconnectedArea?.classList.remove('hidden');
        connectBtn?.classList.add('hidden');
        reconnectBtn?.classList.remove('hidden');
      } else {
        // disconnected — sem instância
        statusInd?.classList.remove('connected');
        if (statusText) statusText.textContent = 'Desconectado';
        disconnectedArea?.classList.remove('hidden');
        connectedArea?.classList.add('hidden');
        connectBtn?.classList.remove('hidden');
        reconnectBtn?.classList.add('hidden');
      }
    }

    function formatPhoneNumber(num: string) {
      if (!num) return '';
      const digits = num.replace(/\D/g, '');
      if (digits.length === 13) { // 55 + DDD + 9 dígitos
        return `+${digits.slice(0,2)} (${digits.slice(2,4)}) ${digits.slice(4,9)}-${digits.slice(9)}`;
      }
      if (digits.length === 12) { // 55 + DDD + 8 dígitos
        return `+${digits.slice(0,2)} (${digits.slice(2,4)}) ${digits.slice(4,8)}-${digits.slice(8)}`;
      }
      return num;
    }

    async function saveWhatsAppStatus(status, number = null) {
      try {
        if (!cachedEstudioId) {
          const { data: { user } } = await supabase.auth.getUser();
          const { data: estudio } = await supabase.from('users').select('estudio_id').eq('id', user.id).single();
          cachedEstudioId = estudio?.estudio_id;
        }

        const updateData: any = {
          status,
          updated_at: new Date().toISOString()
        };

        if (status === 'disconnected') {
          updateData.numero_conectado = null;
          updateData.connected_at = null;
        }

        const { error } = await supabase
          .from('conexao_whatsapp')
          .update(updateData)
          .eq('estudio_id', cachedEstudioId);

        if (error) throw error;
        updateWhatsAppUI(status === 'connected' ? 'connected' : 'disconnected', number);
        showToast(status === 'connected' ? 'WhatsApp conectado!' : 'WhatsApp desconectado.', 'info');
      } catch (err) {
        showToast('Erro ao atualizar status do WhatsApp.', 'error');
      }
    }

    function openIAModal(original) {
      document.getElementById('ia-original-text').textContent = original;
      
      // Mock de geração
      const suggestions = [
        "Olá {cliente_nome}! ✨ Confirmando nossa sessão marcada com {tatuador_nome} para o dia {data} às {hora}. Mal posso esperar para ver o resultado! Responda SIM para confirmar.",
        "Oi {cliente_nome}, tudo bem? Aqui é do {estudio_nome}. Passando para confirmar seu horário amanhã ({data}) às {hora}. Nos vemos em breve! 🔥",
        "E aí {cliente_nome}! Seu horário com {tatuador_nome} está chegando! Dia {data}, às {hora}. Confirma sua presença? 🤘"
      ];
      
      document.getElementById('ia-suggested-text').textContent = "Gerando sugestão...";
      document.getElementById('modal-ia').classList.remove('hidden');
      
      setTimeout(() => {
        document.getElementById('ia-suggested-text').textContent = suggestions[Math.floor(Math.random() * suggestions.length)];
      }, 1200);
    }

    function showToast(msg, type = 'info') {
      // Remoção de alertas nativos conforme pedido do usuário.
      // Feedback opcional via console para debug.
      console.log(`[Toast ${type}]: ${msg}`);
    }

    // INIT
    init();
  </script>
</DashboardLayout>
