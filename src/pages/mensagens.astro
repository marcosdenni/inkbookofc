---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { supabase } from '../lib/supabase';

// Título: Mensagens
---

<DashboardLayout title="Mensagens">
  <div class="mensagens-wrapper">
    <!-- ═══ HEADER ═══ -->
    <header class="mensagens-header">
      <div class="header-titles">
        <h1 class="page-title">MENSAGENS</h1>
        <p class="subtitle">Personalize as mensagens automáticas e gerencie sua conexão</p>
      </div>
    </header>

    <div class="mensagens-grid">
      <!-- ═══ SEÇÃO 1: TEMPLATES ═══ -->
      <section class="section-container">
        <div class="section-header">
          <div class="header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-template"><rect width="18" height="7" x="3" y="3" rx="1"/><rect width="9" height="7" x="3" y="14" rx="1"/><rect width="5" height="7" x="16" y="14" rx="1"/></svg>
          </div>
          <div class="header-text">
            <h2>Templates de Mensagens</h2>
            <p>Configure os textos enviados automaticamente aos clientes.</p>
          </div>
        </div>

        <div class="variables-bar">
          <span class="var-label">Variáveis disponíveis (clique para inserir):</span>
          <div class="var-chips">
            <button class="var-chip" data-var={"{cliente_nome}"}>{"{cliente_nome}"}</button>
            <button class="var-chip" data-var={"{tatuador_nome}"}>{"{tatuador_nome}"}</button>
            <button class="var-chip" data-var={"{data}"}>{"{data}"}</button>
            <button class="var-chip" data-var={"{hora}"}>{"{hora}"}</button>
            <button class="var-chip" data-var={"{valor}"}>{"{valor}"}</button>
            <button class="var-chip" data-var={"{estudio_nome}"}>{"{estudio_nome}"}</button>
          </div>
        </div>

        <div class="templates-list">
          <!-- Template: Confirmação -->
          <div class="template-card" data-tipo="agendamento_criado">
            <div class="card-title">
              <h3>Confirmação de Agendamento</h3>
              <span class="char-count">0 / 500</span>
            </div>
            <textarea placeholder={"Ex: Olá {cliente_nome}, seu agendamento está confirmado..."}></textarea>
            <div class="card-actions">
              <button class="btn-ia-optimize">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                Otimizar com IA
              </button>
              <button class="btn-save-template">Salvar</button>
            </div>
          </div>

          <!-- Template: Lembrete -->
          <div class="template-card" data-tipo="lembrete_sessao">
            <div class="card-title">
              <h3>Lembrete de Sessão</h3>
              <span class="char-count">0 / 500</span>
            </div>
            <textarea placeholder={"Ex: Olá {cliente_nome}, lembramos que sua sessão é amanhã..."}></textarea>
            <div class="card-actions">
              <button class="btn-ia-optimize">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                Otimizar com IA
              </button>
              <button class="btn-save-template">Salvar</button>
            </div>
          </div>

          <!-- Template: Cancelamento -->
          <div class="template-card" data-tipo="Cancelamento">
            <div class="card-title">
              <h3>Aviso de Cancelamento</h3>
              <span class="char-count">0 / 500</span>
            </div>
            <textarea placeholder={"Ex: Olá {cliente_nome}, seu agendamento foi cancelado..."}></textarea>
            <div class="card-actions">
              <button class="btn-ia-optimize">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                Otimizar com IA
              </button>
              <button class="btn-save-template">Salvar</button>
            </div>
          </div>

          <!-- Template: Resposta de Confirmação de Presença -->
          <div class="template-card" data-tipo="confirmacao_presenca">
            <div class="card-title">
              <div class="card-title-text">
                <h3>Confirmação de presença</h3>
                <p style="font-size: 0.8rem; color: #666; font-weight: 500; margin-top: 0.25rem;">Mensagem enviada automaticamente quando o cliente confirma o horário respondendo no WhatsApp.</p>
              </div>
              <span class="char-count">0 / 500</span>
            </div>
            <textarea placeholder={"Perfeito, {cliente_nome}! 🙌\n\nSeu horário está confirmado no *{estudio_nome}*.\n\n📅 {data} às {hora}  \n🎨 Com {tatuador_nome}\n\nQualquer dúvida é só falar com a gente. Te esperamos no estúdio! 🔥"}></textarea>
            <div class="card-actions">
              <button class="btn-ia-optimize">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                Otimizar com IA
              </button>
              <button class="btn-save-template">Salvar</button>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══ SEÇÃO 2: WHATSAPP ═══ -->
      <section class="section-container side-section">
        <div class="section-header">
          <div class="header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
          </div>
          <div class="header-text">
            <h2>Conexão WhatsApp</h2>
            <p>Gerencie a integração com o WhatsApp Business.</p>
          </div>
        </div>

        <div class="whatsapp-card card-premium">
          <div class="status-indicator" id="whatsapp-status">
            <div class="status-dot"></div>
            <span class="status-text">Desconectado</span>
          </div>

          <div id="whatsapp-disconnected" class="whatsapp-action-area">
            <div class="qr-placeholder">
              <div class="qr-mock">
                <!-- SVG de QR Code Mock -->
                <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="200" height="200" rx="10" fill="#0d0d0d"/>
                  <rect x="20" y="20" width="40" height="40" stroke="#333" stroke-width="4"/>
                  <rect x="140" y="20" width="40" height="40" stroke="#333" stroke-width="4"/>
                  <rect x="20" y="140" width="40" height="40" stroke="#333" stroke-width="4"/>
                  <path d="M80 20H120V60H80V20Z" fill="#222"/>
                  <path d="M20 80H60V120H20V80Z" fill="#222"/>
                  <path d="M140 80H180V120H140V80Z" fill="#222"/>
                  <path d="M80 140H120V180H80V140Z" fill="#222"/>
                  <path d="M140 140H180V180H140V140Z" fill="#111"/>
                  <path d="M80 80H120V120H80V80Z" fill="#333" fill-opacity="0.5"/>
                </svg>
                <div class="qr-overlay">Clique para gerar QR Code</div>
              </div>
              <p class="qr-hint">Escaneie o QR Code para conectar seu WhatsApp Business</p>
            </div>
            <button class="btn-premium-solid" id="btn-connect-wa">Conectar WhatsApp</button>
            <button class="btn-premium-solid hidden" id="btn-reconnect-wa">Reconectar WhatsApp</button>
          </div>

          <div id="whatsapp-connected" class="whatsapp-action-area hidden">
            <div class="connection-info">
              <div class="connected-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="#25D366" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.656 1.438 5.166L2 22l4.934-1.42A9.956 9.956 0 0 0 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.96 7.96 0 0 1-4.164-1.17l-.297-.177-3.073.885.843-3.144-.194-.311A8 8 0 1 1 12 20z"/></svg>
              </div>
              <h3>Pronto para enviar!</h3>
            <button class="btn-danger-outline" id="btn-disconnect-wa" style="margin-top: 1.5rem;">Desconectar</button>
          </div>
        </div>
      </section>
      <!-- ═══ SEÇÃO 3: CONFIGURAÇÃO DE LEMBRETE ═══ -->
      <section class="section-container side-section" style="margin-top: 1.5rem;">
        <div class="section-header">
          <div class="header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="header-text">
            <h2>Configuração de Lembrete</h2>
            <p>Defina quando o lembrete será enviado.</p>
          </div>
        </div>

        <div class="reminders-card" style="background: #141414; border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 2rem; display: flex; flex-direction: column; gap: 1rem;">
          <div class="form-group" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <label for="select-lembrete-tempo" style="font-size: 0.9rem; font-weight: 700; color: #eee; display: block;">Enviar lembrete antes da sessão</label>
            <div class="select-wrapper" style="position: relative;">
              <select id="select-lembrete-tempo" style="width: 100%; background: #0d0d0d; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; padding: 0.85rem 1rem; color: #fff; font-size: 1rem; appearance: none; cursor: pointer; transition: all 0.2s ease;">
                <option value="1440">24 horas</option>
                <option value="720">12 horas</option>
                <option value="360">6 horas</option>
                <option value="180">3 horas</option>
                <option value="120">2 horas</option>
                <option value="60">1 hora</option>
                <option value="30">30 minutos</option>
              </select>
              <div style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); pointer-events: none; color: #777;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>
          <p class="config-hint" style="font-size: 0.8rem; color: #555; line-height: 1.4; margin: 0;">O sistema usará essa configuração para enviar automaticamente lembretes de agendamento ao cliente no WhatsApp antes da sessão.</p>
        </div>
      </section>
    </div>

    <!-- ═══ MODAL IA ═══ -->
    <div id="modal-ia" class="modal-premium-overlay hidden">
      <div class="modal-premium-card">
        <header class="modal-header">
          <div class="ia-icon">
             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bot"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
          </div>
          <div class="header-text">
            <h2>Otimização com IA</h2>
            <p>Compare as sugestões para tornar suas mensagens mais envolventes.</p>
          </div>
          <button class="modal-close-btn">&times;</button>
        </header>
        
        <div class="modal-content">
          <div class="comparison-grid">
            <div class="comparison-card">
              <span class="badge">ORIGINAL</span>
              <div class="text-box" id="ia-original-text"></div>
            </div>
            <div class="comparison-card accent">
              <span class="badge">SUGESTÃO IA ✨</span>
              <div class="text-box" id="ia-suggested-text"></div>
            </div>
          </div>
        </div>

        <footer class="modal-footer">
          <button class="btn-secondary modal-close-btn">Manter Original</button>
          <button id="btn-use-suggestion" class="btn-primary-glow">
            <span class="btn-text">Usar Sugestão</span>
            <div class="btn-loader hidden">
              <svg class="animate-spin" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </div>
          </button>
        </footer>
      </div>
    </div>

    <!-- ═══ MODAL CONFIRMAÇÃO DESCONECTAR ═══ -->
    <div id="modal-disconnect-confirm" class="modal-overlay-delete hidden">
      <div class="modal-content-delete sm">
        <div class="modal-header-delete">
          <h2 style="color: #ef4444;">Desconectar WhatsApp?</h2>
        </div>
        
        <p style="margin: 1.5rem 0; color: #ccc; line-height: 1.5;">
          Sua automação de mensagens será interrompida. O sistema deixará de enviar confirmações e lembretes automáticos.
        </p>

        <div class="alert-warning-delete">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <span>Esta ação pode ser revertida conectando novamente o QR Code.</span>
        </div>

        <div class="modal-footer-delete">
          <button class="btn-secondary-delete modal-close-disconnect">Cancelar</button>
          <button id="btn-confirm-disconnect" class="btn-danger-full-delete">Sim, Desconectar</button>
        </div>
      </div>
    </div>

    <!-- ═══ MODAL QR CODE ═══ -->
    <div id="modal-qr" class="modal-premium-overlay hidden">
      <div class="modal-qr-card">
        <header class="modal-qr-header">
          <div class="whatsapp-icon-modal">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#25D366">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M5.282 3.021C4.1 4.255 3 6.21 3 8.5c0 1.55.388 3.006 1.073 4.28L3 21l8.38-1.052C12.74 20.608 14.118 21 15.5 21c5.247 0 9.5-4.253 9.5-9.5S20.747 2 15.5 2c-2.29 0-4.366.748-6.034 2H8a9.57 9.57 0 0 0-2.718 1.021z" opacity="0" />
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.656 1.438 5.166L2 22l4.934-1.42A9.956 9.956 0 0 0 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.96 7.96 0 0 1-4.164-1.17l-.297-.177-3.073.885.843-3.144-.194-.311A8 8 0 1 1 12 20z"/>
            </svg>
          </div>
          <div class="modal-qr-title-block">
            <h2>Conectar WhatsApp</h2>
            <p>Escaneie o QR Code com seu WhatsApp para conectar.</p>
          </div>
          <button class="modal-close-btn" id="btn-close-qr-modal">&times;</button>
        </header>

        <div class="modal-qr-body">
          <!-- Estado: Carregando -->
          <div id="qr-loading" class="qr-state">
            <div class="qr-spinner"></div>
            <p>Gerando QR Code...</p>
          </div>

          <!-- Estado: QR Exibido -->
          <div id="qr-display" class="qr-state hidden">
            <div class="qr-image-wrapper">
              <img id="qr-image" src="" alt="QR Code WhatsApp" />
            </div>
            <p class="qr-scan-hint">Abra o WhatsApp → Configurações → Aparelhos conectados → Conectar aparelho</p>
          </div>

          <!-- Estado: Expirado -->
          <div id="qr-expired" class="qr-state hidden">
            <div class="qr-expired-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
            </div>
            <p class="qr-expired-text">QR expirado</p>
            <button class="btn-premium-solid btn-renew-qr" id="btn-renew-qr">Gerar novo QR</button>
          </div>
        </div>

        <div class="modal-qr-footer">
          <span class="qr-timer" id="qr-timer"></span>
        </div>
      </div>
    </div>
  </div>

  <style is:global>
    .mensagens-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 1rem;
      animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      width: 100%;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* HEADER */
    .mensagens-header {
      margin-bottom: 3rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding-bottom: 2rem;
    }

    .page-title {
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--primary, #C9A24D);
      letter-spacing: -2px;
      margin: 0;
      line-height: 1;
      font-family: 'Bebas Neue', sans-serif;
    }

    .subtitle {
      color: var(--text-muted, #888);
      font-size: 1.1rem;
      font-weight: 500;
      margin-top: 0.5rem;
    }

    /* GRID */
    .mensagens-grid {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 2.5rem;
    }

    @media (max-width: 1100px) {
      .mensagens-grid {
        grid-template-columns: 1fr;
      }
    }

    /* SECTION CONTAINER */
    .section-container {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .section-header {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .header-icon {
      width: 44px;
      height: 44px;
      background: rgba(201, 162, 77, 0.1);
      border: 1px solid rgba(201, 162, 77, 0.2);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary, #C9A24D);
      flex-shrink: 0;
    }

    .header-text h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      color: #fff;
      letter-spacing: 1px;
      margin: 0;
    }

    .header-text p {
      color: #777;
      font-size: 0.95rem;
